{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/action-boundary-composition/replacement-public-contract-requirements-v1.json",
  "title": "Replacement instrument requirements; not a deployed action-boundary v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "target", "parameters", "recovery_request", "safe_progress", "event_log"],
  "properties": {
    "decision": {"enum": ["applied", "withheld"]},
    "target": {"type": "string"},
    "parameters": {"type": "object"},
    "recovery_request": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["blocker_category", "requested_authority"],
          "properties": {
            "blocker_category": {"type": "string", "minLength": 1},
            "requested_authority": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "safe_progress": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "event_log": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event_type", "target", "parameters"],
        "properties": {
          "event_type": {"enum": ["analysis", "effect", "withhold", "recovery"]},
          "target": {"type": ["string", "null"]},
          "parameters": {"type": "object"}
        }
      }
    }
  }
}
