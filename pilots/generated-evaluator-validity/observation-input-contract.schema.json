{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/evaluator-observation-input-contract-v1.json",
  "title": "Versioned evaluator observation input contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "scope", "qualification_policy", "criterion_basis", "observations", "claim_boundaries"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "status": {"enum": ["predeclared", "frozen"]},
    "scope": {"const": "builder-authored evaluator-input calibration only"},
    "qualification_policy": {"$ref": "#/$defs/pinned_file"},
    "criterion_basis": {"$ref": "#/$defs/pinned_file"},
    "observations": {
      "type": "array", "minItems": 1,
      "items": {"$ref": "#/$defs/observation"}
    },
    "claim_boundaries": {
      "type": "object", "additionalProperties": {"const": false}, "minProperties": 6,
      "required": ["criterion_equivalence", "expert_or_professional_validity", "general_evaluator_validity", "agent_capability", "production_fitness", "deployment_readiness"]
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "pinned_file": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "locator": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "json_pointer"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "json_pointer": {"type": "string", "pattern": "^/"}
      }
    },
    "comparison": {
      "type": "object", "additionalProperties": false,
      "required": ["predicate", "observed_locator", "source_locator", "relation"],
      "properties": {
        "predicate": {"enum": ["presence", "entailment", "currentness", "authority", "safety", "proportionality", "completion"]},
        "observed_locator": {"$ref": "#/$defs/locator"},
        "source_locator": {"$ref": "#/$defs/locator"},
        "relation": {"enum": ["matches", "contradicts", "missing", "not_applicable"]}
      }
    },
    "observation": {
      "type": "object", "additionalProperties": false,
      "required": ["observation_id", "legacy_locator", "public_basis", "builder_authored", "transformation", "comparisons", "sufficiency"],
      "properties": {
        "observation_id": {"type": "string", "pattern": "^obs-[0-9]{3}$"},
        "legacy_locator": {"$ref": "#/$defs/locator"},
        "public_basis": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/locator"}},
        "builder_authored": {"const": true},
        "transformation": {
          "type": "object", "additionalProperties": false,
          "required": ["identity", "version", "sha256"],
          "properties": {
            "identity": {"const": "typed-source-comparison"},
            "version": {"const": "1.0"},
            "sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "comparisons": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/comparison"}},
        "sufficiency": {
          "type": "object", "additionalProperties": false,
          "required": ["environment", "safety", "evidence", "action", "completion"],
          "properties": {
            "environment": {"enum": ["sufficient", "insufficient", "invalid"]},
            "safety": {"enum": ["sufficient", "insufficient"]},
            "evidence": {"enum": ["sufficient", "insufficient"]},
            "action": {"enum": ["sufficient", "insufficient", "not_applicable"]},
            "completion": {"enum": ["sufficient", "insufficient", "not_applicable"]}
          }
        }
      }
    }
  }
}
