    {
      "clause_id": "order-and-deduplicate-events",
      "instruction": "Replay journal events in ascending sequence-number order, rejecting duplicate sequence numbers before mutating state.",
      "proposition_basis": [
        "Z-P1"
      ]
    },
    {
      "clause_id": "bind-and-durably-commit-mutations",
      "instruction": "Assign each mutation to the currently open innermost transaction, and make it durable only if that transaction and every ancestor commit.",
      "proposition_basis": [
        "Z-P2"
      ]
    },
    {
      "clause_id": "discard-rolled-back-mutations",
      "instruction": "On rollback, discard the target transaction's mutations and those of all still-open descendants, recording their identifiers in rollback order.",
      "proposition_basis": [
        "Z-P3"
      ]
    },
    {
      "clause_id": "invalidate-structurally-open-journals",
      "instruction": "Treat an unmatched close or any transaction still open at journal end as invalid, leaving no certified final state.",
      "proposition_basis": [
        "Z-P4"
      ]
    }
  ],
