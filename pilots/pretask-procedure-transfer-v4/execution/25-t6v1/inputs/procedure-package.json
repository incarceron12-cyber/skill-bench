  "clauses": [
    {
      "clause_id": "zeta-z-p1",
      "instruction": "Replay journal events in ascending sequence number and reject duplicate sequence numbers before state mutation.",
      "proposition_basis": [
        "Z-P1"
      ]
    },
    {
      "clause_id": "zeta-z-p2",
      "instruction": "A mutation belongs to the outermost open transaction and becomes durable when that transaction commits.",
      "proposition_basis": [
        "Z-P2"
      ]
    },
    {
      "clause_id": "zeta-z-p3",
      "instruction": "Rollback discards the target transaction mutations and all still-open descendants, recording their identifiers in rollback order.",
      "proposition_basis": [
        "Z-P3"
      ]
    },
    {
      "clause_id": "zeta-z-p4",
      "instruction": "An unmatched close or any open transaction at end of journal makes replay invalid and leaves no certified final state.",
      "proposition_basis": [
        "Z-P4"
      ]
    }
  ],
  "contradictions": [
    {
      "content": "Commit makes nested mutations conditionally durable; a later ancestor rollback still discards them.",
