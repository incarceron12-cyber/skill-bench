{
  "policy_id": "parser.semantic-topic.v3",
  "normalization": "NFKC lowercase; underscores/hyphens to spaces; strip punctuation; collapse whitespace",
  "resolution": "one topic whose trigger vocabulary occurs=matched; multiple topics=ambiguous; none=unmatched; malformed=parser_error",
  "receipt_fields": ["status", "normalized_interpreted_topic", "repair_eligible"],
  "receipt_forbidden": ["evidence_id", "candidate", "menu", "availability", "value", "content", "answer"],
  "topics": {
    "vendor-disposition": {
      "permit status": ["permit", "license", "registry", "authorization"],
      "insurance status": ["insurance", "coverage", "certificate"],
      "complaint context": ["complaint", "concern", "incident"]
    },
    "segment-release": {
      "metric semantics": ["dictionary", "definition", "semantics"],
      "adjusted quality audit": ["audit", "eligible", "eligibility", "adjusted", "sample size"],
      "dashboard context": ["dashboard", "owner note", "dashboard note"]
    }
  },
  "topic_to_private_evidence_id": {
    "vendor-disposition": {"permit status": "permit-record", "insurance status": "insurance-record", "complaint context": "complaint-detail"},
    "segment-release": {"metric semantics": "metric-dictionary", "adjusted quality audit": "quality-audit", "dashboard context": "dashboard-note"}
  }
}
