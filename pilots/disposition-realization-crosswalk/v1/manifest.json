        {"id": "absent-receipt-detected", "dimension": "handoff_transport", "op": "equal", "left": {"literal": null, "provenance": "builder_planted_absent_receipt"}, "right": {"literal": "receipt_required"}},
        {"id": "continuation-unavailable", "dimension": "continuation", "op": "unsupported", "reason": "No continuation is credited when the planted handoff has no receipt."},
        {"id": "consequence-unobserved", "dimension": "consequence", "op": "unsupported", "reason": "No consequence was invented for the planted control."},
