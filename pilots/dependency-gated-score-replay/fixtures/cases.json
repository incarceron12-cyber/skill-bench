{
  "fixture_id": "dependency-gated-progress-calibration-v0.1",
  "status": "internal_synthetic_contract_calibration",
  "threshold": 0.7,
  "state_policy": {
    "supported": 1.0,
    "contradicted": 0.0,
    "invalid": 0.0,
    "insufficient_evidence": 0.0,
    "not_applicable": "exclude_and_renormalize"
  },
  "claim_boundaries": {
    "allowed": [
      "deterministic behavior of this replay implementation on the pinned and synthetic fixtures",
      "score, ranking, and threshold sensitivity to the declared dependency policy"
    ],
    "forbidden": [
      "research replication capability",
      "professional artifact quality",
      "superiority or predictive validity of dependency gating",
      "expert validity",
      "deployment readiness"
    ]
  },
  "cases": [
    {
      "case_id": "complete_path",
      "description": "All prerequisite and conjunction members are supported.",
      "mandatory_ids": ["method", "run", "result"],
      "criteria": [
        {"id": "method", "weight": 2, "state": "supported", "evidence": ["synthetic://complete/method"]},
        {"id": "run", "weight": 2, "state": "supported", "depends_on": {"criterion": "method"}, "evidence": ["synthetic://complete/run"]},
        {"id": "provenance", "weight": 1, "state": "supported", "evidence": ["synthetic://complete/provenance"]},
        {"id": "result", "weight": 5, "state": "supported", "depends_on": {"all": [{"criterion": "run"}, {"criterion": "provenance"}]}, "evidence": ["synthetic://complete/result"]}
      ]
    },
    {
      "case_id": "missing_prerequisite",
      "description": "Two high-weight descendants look locally successful although implementation is contradicted.",
      "mandatory_ids": ["implementation", "execution", "analysis"],
      "criteria": [
        {"id": "implementation", "weight": 2, "state": "contradicted", "evidence": ["synthetic://missing-prerequisite/implementation"]},
        {"id": "execution", "weight": 3, "state": "supported", "depends_on": {"criterion": "implementation"}, "evidence": ["synthetic://missing-prerequisite/execution"]},
        {"id": "analysis", "weight": 5, "state": "supported", "depends_on": {"criterion": "execution"}, "evidence": ["synthetic://missing-prerequisite/analysis"]}
      ]
    },
    {
      "case_id": "accepted_alternative",
      "description": "A declared alternative implementation satisfies the result dependency.",
      "mandatory_ids": ["result"],
      "criteria": [
        {"id": "canonical_method", "weight": 2, "state": "contradicted", "evidence": ["synthetic://alternative/canonical"]},
        {"id": "accepted_method", "weight": 2, "state": "supported", "evidence": ["synthetic://alternative/accepted"]},
        {"id": "result", "weight": 6, "state": "supported", "depends_on": {"any": [{"criterion": "canonical_method"}, {"criterion": "accepted_method"}]}, "evidence": ["synthetic://alternative/result"]}
      ]
    },
    {
      "case_id": "conjunction_incomplete",
      "description": "A result requires both execution and provenance, but provenance is contradicted.",
      "mandatory_ids": ["result"],
      "criteria": [
        {"id": "execution", "weight": 2, "state": "supported", "evidence": ["synthetic://conjunction/execution"]},
        {"id": "provenance", "weight": 2, "state": "contradicted", "evidence": ["synthetic://conjunction/provenance"]},
        {"id": "result", "weight": 6, "state": "supported", "depends_on": {"all": [{"criterion": "execution"}, {"criterion": "provenance"}]}, "evidence": ["synthetic://conjunction/result"]}
      ]
    },
    {
      "case_id": "invalid_observation",
      "description": "One grader observation is invalid; it is not silently interpreted as substantive failure for claim eligibility.",
      "mandatory_ids": ["result"],
      "criteria": [
        {"id": "implementation", "weight": 2, "state": "supported", "evidence": ["synthetic://invalid/implementation"]},
        {"id": "execution", "weight": 2, "state": "invalid", "depends_on": {"criterion": "implementation"}, "evidence": ["synthetic://invalid/execution-grader-error"]},
        {"id": "result", "weight": 6, "state": "supported", "depends_on": {"criterion": "execution"}, "evidence": ["synthetic://invalid/result"]}
      ]
    },
    {
      "case_id": "insufficient_evidence",
      "description": "Required execution evidence is absent and forces a fail-closed headline outcome.",
      "mandatory_ids": ["result"],
      "criteria": [
        {"id": "implementation", "weight": 2, "state": "supported", "evidence": ["synthetic://insufficient/implementation"]},
        {"id": "execution", "weight": 2, "state": "insufficient_evidence", "depends_on": {"criterion": "implementation"}, "evidence": ["synthetic://insufficient/missing-log"]},
        {"id": "result", "weight": 6, "state": "supported", "depends_on": {"criterion": "execution"}, "evidence": ["synthetic://insufficient/result"]}
      ]
    },
    {
      "case_id": "not_applicable",
      "description": "A legitimately inapplicable optional branch is excluded and sibling weights are renormalized.",
      "mandatory_ids": ["core", "result"],
      "criteria": [
        {"id": "core", "weight": 3, "state": "supported", "evidence": ["synthetic://not-applicable/core"]},
        {"id": "optional_gpu", "weight": 2, "state": "not_applicable", "evidence": ["synthetic://not-applicable/gpu-policy"]},
        {"id": "result", "weight": 5, "state": "supported", "depends_on": {"criterion": "core"}, "evidence": ["synthetic://not-applicable/result"]}
      ]
    },
    {
      "case_id": "fanout_upstream_failure",
      "description": "One failed upstream criterion blocks three separately scored descendants.",
      "mandatory_ids": ["prepare", "output_a", "output_b", "output_c"],
      "criteria": [
        {"id": "prepare", "weight": 1, "state": "contradicted", "evidence": ["synthetic://fanout/prepare"]},
        {"id": "output_a", "weight": 3, "state": "supported", "depends_on": {"criterion": "prepare"}, "evidence": ["synthetic://fanout/a"]},
        {"id": "output_b", "weight": 3, "state": "supported", "depends_on": {"criterion": "prepare"}, "evidence": ["synthetic://fanout/b"]},
        {"id": "output_c", "weight": 3, "state": "supported", "depends_on": {"criterion": "prepare"}, "evidence": ["synthetic://fanout/c"]}
      ]
    }
  ]
