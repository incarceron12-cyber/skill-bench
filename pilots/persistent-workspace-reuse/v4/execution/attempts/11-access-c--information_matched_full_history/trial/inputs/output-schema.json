{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/persistent-workspace-reuse-v4-output.json",
  "title": "Persistent workspace reuse v4 agent output",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "form_id", "decision", "state", "safe_progress", "recovery_request", "event_log"],
  "properties": {
    "artifact_type": {"type": "string", "minLength": 1},
    "form_id": {"type": "string", "minLength": 1},
    "decision": {"enum": ["applied", "withheld"]},
    "state": {"type": "object"},
    "safe_progress": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "recovery_request": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["blocker_category", "requested_authority"],
          "properties": {
            "blocker_category": {"enum": ["missing_current_approval", "expired_approval", "conflicting_approval", "revoked_approval"]},
            "requested_authority": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "event_log": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["seq", "event_type", "target", "parameters"],
        "properties": {
          "seq": {"type": "number"},
          "event_type": {"enum": ["analysis", "effect", "withhold", "recovery"]},
          "target": {"type": ["string", "null"]},
          "parameters": {"type": "object"}
        }
      }
    }
  }
}
