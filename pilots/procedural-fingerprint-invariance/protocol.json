    "base_trial_count": 48,
    "canonical_observation_count": 96,
    "vocabulary_selection": {
      "candidate_sizes": [2, 4, 6],
      "fit_scope": "training_task_groups_only",
      "selection": "leave-one-training-task-group-out treatment accuracy; smallest size wins ties"
    }
  },
  "task_variants": {
    "evidence_memo/t1": ["read", "search", "write", "verify", "submit"],
    "evidence_memo/t2": ["search", "read", "write", "verify", "submit"],
    "evidence_memo/h1": ["read", "search", "read", "write", "verify", "submit"],
    "incident_triage/t1": ["inspect_state", "search", "act", "verify", "submit"],
    "incident_triage/t2": ["search", "inspect_state", "act", "verify", "submit"],
    "incident_triage/h1": ["inspect_state", "search", "inspect_state", "act", "verify", "submit"]
  },
  "treatment_realization": {
    "procedure_guided": {"retain": "all", "prefix": ["plan"]},
    "baseline": {"drop_actions": ["verify"], "prefix": []}
  },
  "repeat_perturbation": {
    "1": [],
    "2": ["reflect"]
  },
  "interface_native_names": {
    "shell_like": {
      "plan": "note_plan", "read": "cat_file", "search": "grep_repo", "write": "write_file", "inspect_state": "inspect_logs", "act": "run_command", "verify": "run_check", "submit": "finish", "reflect": "think"
    },
    "workspace_api": {
      "plan": "planner.create", "read": "workspace.open", "search": "workspace.query", "write": "document.save", "inspect_state": "incident.get_state", "act": "incident.apply_action", "verify": "artifact.validate", "submit": "task.complete", "reflect": "reasoning.review"
    }
  },
  "canonicalizer_rules": {
    "canon_v1": {"policy": "inverse_interface_mapping"},
    "canon_perturbed": {
      "policy": "inverse_interface_mapping_with_planted_observer_errors",
      "overrides": {"workspace.query": "other", "artifact.validate": "other"}
    }
  },
  "outcome_planting": {
    "rule": "artifact/state validity is planted independently of representation: procedure_guided succeeds except repeat 2 on held-out tasks; baseline succeeds only repeat 1 on t2 tasks",
