      "clause_id": "classify_each_item",
      "instruction": "Classify each item from its own release label before applying any transformation; an unlabeled item remains withheld.",
      "proposition_basis": [
        "D-P1"
      ]
    },
    {
      "clause_id": "transform_candidate_items",
      "instruction": "A transformable item may enter the candidate release only after the named transformation removes every marked segment and the transformed identity is recorded separately from the source identity.",
      "proposition_basis": [
        "D-P2"
      ]
    },
    {
      "clause_id": "enforce_dependency_closure",
      "instruction": "Release is closed under mandatory dependencies: if any required dependency is withheld or invalid, every dependent item is withheld with a propagated reason.",
      "proposition_basis": [
        "D-P3"
      ]
    },
    {
      "clause_id": "produce_final_manifest",
      "instruction": "The final manifest lists every source item exactly once with source identity, released identity or null, disposition, transformation, dependency state, and reason.",
