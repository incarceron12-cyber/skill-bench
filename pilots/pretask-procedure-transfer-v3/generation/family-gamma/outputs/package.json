  "clauses": [
    {
      "clause_id": "exclude_ineligible_requests",
      "instruction": "Remove ineligible requests before ranking and record one explicit exclusion reason for each removed request.",
      "proposition_basis": [
        "G-P1"
      ]
    },
    {
      "clause_id": "rank_eligible_requests",
      "instruction": "Allocate eligible indivisible requests in descending priority, breaking equal priority by earlier submitted sequence and then lexical request identifier.",
      "proposition_basis": [
        "G-P2"
      ]
    },
    {
      "clause_id": "fund_only_full_feasible_requests",
      "instruction": "A request is funded only when its full quantity fits both the remaining total capacity and every applicable reserved-pool constraint; partial funding is forbidden.",
      "proposition_basis": [
        "G-P3"
      ]
    },
    {
      "clause_id": "reconcile_allocation_ledger",
      "instruction": "Close the allocation ledger by reconciling opening capacity, funded quantities by pool, protected residuals, and unassigned residual to the exact total.",
      "proposition_basis": [
        "G-P4"
      ]
    }
  ],
  "omissions": [],
