---
import dashboard from '../data/generated-dashboard.json';

const queue = dashboard.queue as Record<string, number>;
const active = (queue.pending ?? 0) + (queue.claimed ?? 0) + (queue.blocked ?? 0);
const generated = new Date(dashboard.generated_at).toLocaleString('en-GB', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'UTC',
});
---

<div class="research-dashboard">
  <section class="signal-grid" aria-label="Research status">
    <a class="metric-card" href="/papers/">
      <span class="metric-label">Deep reviews</span>
      <strong>{dashboard.paper_count}</strong>
      <span>Full-text research corpus</span>
    </a>
    <a class="metric-card" href="/insights/">
      <span class="metric-label">Insight clusters</span>
      <strong>{dashboard.insight_group_count}</strong>
      <span>Cross-paper conclusions</span>
    </a>
    <a class="metric-card" href="/next-steps/">
      <span class="metric-label">Active work</span>
      <strong>{active}</strong>
      <span>{queue.claimed ?? 0} claimed · {queue.blocked ?? 0} blocked</span>
    </a>
    <a class="metric-card" href="/charter/">
      <span class="metric-label">Scope</span>
      <strong class="metric-word">Broad</strong>
      <span>Knowledge work across domains</span>
    </a>
  </section>

  <section class="focus-panel">
    <div>
      <span class="eyebrow">Current north star</span>
      <h2>Turn domain expertise into realistic, auditable evaluations of agentic knowledge work.</h2>
      <p>
        The benchmark studies messy evidence, professional judgment, tools, workflow state,
        and consequential artifacts—then explains why a configured agent system succeeds or fails.
      </p>
    </div>
    <div class="focus-actions">
      <a class="primary-action" href="/insights/">Explore key insights <span>→</span></a>
      <a class="secondary-action" href="/landscape/">Compare benchmarks</a>
    </div>
  </section>

  <div class="dashboard-columns">
    <section class="dashboard-panel">
      <div class="panel-heading">
        <div>
          <span class="eyebrow">Research direction</span>
          <h2>Highest-priority next steps</h2>
        </div>
        <a href="/next-steps/">View queue →</a>
      </div>
      <div class="task-list">
        {dashboard.top_tasks.map((task) => (
          <article class="task-row">
            <div class="task-meta">
              <span class={`status status-${task.status}`}>{task.status}</span>
              <span class="task-type">{task.type}</span>
              <span class="priority">P{task.priority}</span>
            </div>
            <h3>{task.title}</h3>
            <p>{task.next_action}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="dashboard-panel">
      <div class="panel-heading">
        <div>
          <span class="eyebrow">Evidence stream</span>
          <h2>Latest paper reviews</h2>
        </div>
        <a href="/papers/">All papers →</a>
      </div>
      <div class="review-list">
        {dashboard.latest_reviews.map((review) => (
          <a class="review-row" href={review.url}>
            <span class="review-date">{review.date}</span>
            <strong>{review.title}</strong>
            <span aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </section>
  </div>

  <p class="freshness">Repository projection generated {generated} UTC.</p>
</div>
