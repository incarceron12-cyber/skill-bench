{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/clean-release-manifest.schema.json",
  "title": "skill-bench clean release manifest",
  "type": "object",
  "required": ["schema_version", "release_id", "purpose", "evidence_basis", "aggregation", "packages", "claim_ceiling"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "release_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$"},
    "purpose": {"type": "string", "minLength": 20},
    "evidence_basis": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}},
    "aggregation": {
      "type": "object",
      "required": ["aggregation_id", "version", "estimand", "rule", "denominator_policy", "missing_invalid_policy", "spec_sha256"],
      "additionalProperties": false,
      "properties": {
        "aggregation_id": {"type": "string", "minLength": 3},
        "version": {"type": "string", "minLength": 1},
        "estimand": {"type": "string", "minLength": 10},
        "rule": {"type": "string", "minLength": 10},
        "denominator_policy": {"type": "string", "minLength": 10},
        "missing_invalid_policy": {"type": "string", "minLength": 10},
        "spec_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "packages": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/package"}},
    "claim_ceiling": {"$ref": "#/$defs/claimCeiling"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "file": {
      "type": "object",
      "required": ["path", "sha256"],
      "additionalProperties": false,
      "properties": {"path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "component": {
      "type": "object",
      "required": ["component_id", "role", "path", "sha256", "language", "compile_check", "trust"],
      "additionalProperties": false,
      "properties": {
        "component_id": {"type": "string", "minLength": 3},
        "role": {"enum": ["package_manifest", "task_contract", "evaluator", "adapter", "replay_runner", "result_evidence", "rights_evidence"]},
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "language": {"enum": ["python", "json", "markdown"]},
        "compile_check": {"enum": ["python_compile", "json_parse", "not_executable"]},
        "trust": {"const": "builder_authored_retained"}
      }
    },
    "control": {
      "type": "object",
      "required": ["control_id", "runner_component_id", "argv", "zero_cost", "expected_exit", "timeout_seconds", "expected_stdout", "result_evidence", "expected_evidence"],
      "additionalProperties": false,
      "properties": {
        "control_id": {"type": "string", "minLength": 3},
        "runner_component_id": {"type": "string", "minLength": 3},
        "argv": {"type": "array", "minItems": 2, "items": {"type": "string"}},
        "zero_cost": {"const": true},
        "expected_exit": {"const": 0},
        "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 300},
        "expected_stdout": {
          "oneOf": [
            {"type": "object", "required": ["inline_json"], "additionalProperties": false, "properties": {"inline_json": {}}},
            {"type": "object", "required": ["json_path"], "additionalProperties": false, "properties": {"json_path": {"type": "string", "minLength": 1}}}
          ]
        },
        "result_evidence": {"$ref": "#/$defs/file"},
        "expected_evidence": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["pointer", "equals"], "additionalProperties": false, "properties": {"pointer": {"type": "string", "pattern": "^/"}, "equals": {}}}}
      }
    },
    "containment": {
      "type": "object",
      "required": ["status", "untrusted_execution_allowed", "network", "filesystem", "process_resource_boundary"],
      "additionalProperties": false,
      "properties": {
        "status": {"const": "trusted_builder_code_only"},
        "untrusted_execution_allowed": {"const": false},
        "network": {"enum": ["not_requested_but_not_kernel_blocked"]},
        "filesystem": {"enum": ["repository_read_and_same_byte_report_write"]},
        "process_resource_boundary": {"enum": ["subprocess_timeout_only"]}
      }
    },
    "claimCeiling": {
      "type": "object",
      "required": ["agent_capability", "professional_validity", "production_safety", "production_fitness", "public_release_readiness", "cross_domain_generalization"],
      "additionalProperties": false,
      "properties": {
        "agent_capability": {"const": false}, "professional_validity": {"const": false}, "production_safety": {"const": false},
        "production_fitness": {"const": false}, "public_release_readiness": {"const": false}, "cross_domain_generalization": {"const": false}
      }
    },
    "package": {
      "type": "object",
      "required": ["release_item_id", "package_id", "version", "work_shape", "task_ids", "redistribution", "aggregation_id", "aggregation_spec_sha256", "components", "containment", "controls", "claim_ceiling"],
      "additionalProperties": false,
      "properties": {
        "release_item_id": {"type": "string", "minLength": 3}, "package_id": {"type": "string", "minLength": 3}, "version": {"type": "string", "minLength": 1},
        "work_shape": {"type": "string", "minLength": 3}, "task_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 3}},
        "redistribution": {"type": "object", "required": ["status", "basis", "evidence"], "additionalProperties": false, "properties": {"status": {"const": "affirmed_builder_authored_internal_fixtures"}, "basis": {"type": "string", "minLength": 10}, "evidence": {"$ref": "#/$defs/file"}}},
        "aggregation_id": {"type": "string"}, "aggregation_spec_sha256": {"$ref": "#/$defs/sha256"},
        "components": {"type": "array", "minItems": 3, "items": {"$ref": "#/$defs/component"}},
        "containment": {"$ref": "#/$defs/containment"}, "controls": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/control"}},
        "claim_ceiling": {"$ref": "#/$defs/claimCeiling"}
      }
    }
  }
}
