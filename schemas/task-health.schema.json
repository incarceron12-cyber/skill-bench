{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/task-health.schema.json",
  "title": "skill-bench task health and lifecycle package",
  "description": "Operating-layer evidence for versioned task roles, reference witnesses, replication, adjudication, revision, and retirement.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_id", "version", "artifacts", "evidence", "task_health_records"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "package_id": {"$ref": "#/$defs/id"},
    "version": {"$ref": "#/$defs/text"},
    "artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifact"}},
    "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
    "task_health_records": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/healthRecord"}}
  },
  "$defs": {
    "text": {"type": "string", "minLength": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "ids": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "role": {"enum": ["candidate", "capability_probe", "regression_guard", "critical_diagnostic", "calibration_only", "retired"]},
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "artifact_type", "path", "version", "sha256"],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/id"},
        "artifact_type": {"enum": ["task", "suite", "bundle", "rubric", "criterion_set", "case_assembly", "grader", "configured_system", "harness", "environment", "trial", "transcript", "reference_output", "health_measurement", "population_manifest", "bridge_measurement", "cost_record", "disagreement_record", "adjudication", "benchmark_version"]},
        "path": {"$ref": "#/$defs/path"}, "version": {"$ref": "#/$defs/text"}, "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "evidence_type", "artifact_ref_ids", "locator", "description", "limitations"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/id"},
        "evidence_type": {"enum": ["origin_record", "reference_witness", "contrast_result", "repeated_trials", "human_adjudication", "human_authority", "typed_disagreement", "candidate_history", "bridge_study", "cost_accounting", "grader_adjudication", "usage_relevance", "saturation", "coverage_analysis", "owner_acceptance"]},
        "artifact_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "locator": {"$ref": "#/$defs/text"}, "description": {"$ref": "#/$defs/text"},
        "limitations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}}
      }
    },
    "origin": {
      "type": "object", "additionalProperties": false,
      "required": ["origin_type", "evidence_ids", "privacy_state", "selection_stage", "treatment_outcomes_visible", "admission_influenced_by_outcomes"],
      "properties": {
        "origin_type": {"enum": ["requirement", "manual_check", "production_failure", "user_report", "expert_incident", "synthetic_hypothesis"]},
        "evidence_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "privacy_state": {"enum": ["public", "redacted", "restricted", "synthetic"]},
        "selection_stage": {"enum": ["authoring", "calibration", "confirmatory", "transfer", "operational"]},
        "treatment_outcomes_visible": {"type": "boolean"}, "admission_influenced_by_outcomes": {"type": "boolean"},
        "selection_note": {"$ref": "#/$defs/text"}
      }
    },
    "roleAssignment": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "status", "effective_benchmark_version", "evidence_ids", "intended_use"],
      "properties": {
        "role": {"$ref": "#/$defs/role"}, "status": {"enum": ["active", "inactive", "proposed"]},
        "effective_benchmark_version": {"$ref": "#/$defs/text"}, "evidence_ids": {"$ref": "#/$defs/ids"}, "intended_use": {"$ref": "#/$defs/text"}
      }
    },
    "referenceAttempt": {
      "type": "object", "additionalProperties": false,
      "required": ["attempt_id", "system_kind", "task_ref_id", "grader_ref_ids", "harness_ref_id", "environment_ref_id", "output_ref_id", "evidence_ids", "result", "claim"],
      "properties": {
        "attempt_id": {"$ref": "#/$defs/id"}, "system_kind": {"enum": ["human", "configured_agent", "deterministic_fixture"]},
        "task_ref_id": {"$ref": "#/$defs/id"}, "grader_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "harness_ref_id": {"$ref": "#/$defs/id"}, "environment_ref_id": {"$ref": "#/$defs/id"}, "output_ref_id": {"$ref": "#/$defs/id"},
        "evidence_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "result": {"enum": ["pass", "fail", "invalid"]}, "claim": {"const": "witness_pass_for_exact_versions_only"}
      }
    },
    "contrastCase": {
      "type": "object", "additionalProperties": false,
      "required": ["case_id", "polarity", "trigger_or_boundary", "task_ref_id", "evidence_ids"],
      "properties": {"case_id": {"$ref": "#/$defs/id"}, "polarity": {"enum": ["positive", "negative"]}, "trigger_or_boundary": {"$ref": "#/$defs/text"}, "task_ref_id": {"$ref": "#/$defs/id"}, "evidence_ids": {"$ref": "#/$defs/ids"}}
    },
    "replicationPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["intended_k", "replicate_grouping", "seed_policy", "environment_reset", "environment_fingerprint", "independence_threats", "reporting_policy"],
      "properties": {
        "intended_k": {"type": "integer", "minimum": 1}, "replicate_grouping": {"$ref": "#/$defs/text"}, "seed_policy": {"$ref": "#/$defs/text"},
        "environment_reset": {"$ref": "#/$defs/text"}, "environment_fingerprint": {"$ref": "#/$defs/text"},
        "independence_threats": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
        "reporting_policy": {"enum": ["empirical_group_any_all", "per_attempt_only", "no_independence_extrapolation"]}
      }
    },
    "adjudication": {
      "type": "object", "additionalProperties": false,
      "required": ["adjudication_id", "original_result_ref_id", "observation_basis", "observation_ref_ids", "evidence_ids", "defect_type", "decision", "affected_artifact_ref_ids", "replacement_artifact_ref_ids", "old_score_disposition", "capability_aggregation_disposition", "owner"],
      "properties": {
        "adjudication_id": {"$ref": "#/$defs/id"}, "original_result_ref_id": {"$ref": "#/$defs/id"},
        "observation_basis": {"enum": ["transcript", "artifact_or_outcome", "combined", "insufficient"]},
        "observation_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "evidence_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "defect_type": {"enum": ["none", "task_defect", "grader_defect", "harness_defect", "environment_defect", "accepted_alternative", "agent_failure", "insufficient_observability"]},
        "decision": {"enum": ["retain", "exclude_from_capability", "revise_instrument", "accept_alternative", "unresolved"]},
        "affected_artifact_ref_ids": {"$ref": "#/$defs/ids"}, "replacement_artifact_ref_ids": {"$ref": "#/$defs/ids"},
        "old_score_disposition": {"enum": ["preserve_as_recorded", "void_but_preserve", "not_applicable"]},
        "capability_aggregation_disposition": {"enum": ["include", "exclude", "pending"]}, "owner": {"$ref": "#/$defs/text"}
      }
    },
    "healthSignal": {
      "type": "object", "additionalProperties": false,
      "required": ["signal", "status", "evidence_ids", "interpretation"],
      "properties": {
        "signal": {"enum": ["repeat_stability", "invalid_run_rate", "unresolved_instrument_invalidity", "grader_human_disagreement", "saturation", "usage_relevance", "critical_coverage"]},
        "status": {"enum": ["acceptable", "unacceptable", "unknown", "observed_not_sufficient"]},
        "evidence_ids": {"$ref": "#/$defs/ids"}, "interpretation": {"$ref": "#/$defs/text"}
      }
    },
    "transition": {
      "type": "object", "additionalProperties": false,
      "required": ["transition_id", "from_role", "to_role", "rationale", "evidence_ids", "approver", "effective_benchmark_version", "bridge_required", "regression_consequence"],
      "properties": {
        "transition_id": {"$ref": "#/$defs/id"}, "from_role": {"$ref": "#/$defs/role"}, "to_role": {"$ref": "#/$defs/role"},
        "rationale": {"$ref": "#/$defs/text"}, "evidence_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "approver": {"$ref": "#/$defs/text"}, "effective_benchmark_version": {"$ref": "#/$defs/text"}, "bridge_required": {"type": "boolean"},
        "regression_consequence": {"$ref": "#/$defs/text"}
      }
    },
    "revision": {
      "type": "object", "additionalProperties": false,
      "required": ["revision_id", "reason", "old_artifact_ref_ids", "new_artifact_ref_ids", "evidence_ids", "comparability", "old_scores_preserved"],
      "properties": {
        "revision_id": {"$ref": "#/$defs/id"}, "reason": {"$ref": "#/$defs/text"}, "old_artifact_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "new_artifact_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "evidence_ids": {"$ref": "#/$defs/ids"},
        "comparability": {"enum": ["preserved", "bridge_required", "broken"]}, "old_scores_preserved": {"type": "boolean"}
      }
    },
    "retirement": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "reason", "replacement_task_ref_ids", "critical_coverage_disposition", "comparability_decision", "evidence_ids"],
      "properties": {
        "status": {"enum": ["not_retired", "proposed", "retired"]}, "reason": {"$ref": "#/$defs/text"}, "replacement_task_ref_ids": {"$ref": "#/$defs/ids"},
        "critical_coverage_disposition": {"$ref": "#/$defs/text"}, "comparability_decision": {"$ref": "#/$defs/text"}, "evidence_ids": {"$ref": "#/$defs/ids"}
      }
    },
    "evolutionPartition": {
      "type": "object", "additionalProperties": false,
      "required": ["partition_id", "role", "manifest_ref_id", "visible_to_adaptation", "use"],
      "properties": {
        "partition_id": {"$ref": "#/$defs/id"}, "role": {"enum": ["development", "confirmation", "frozen_bridge"]},
        "manifest_ref_id": {"$ref": "#/$defs/id"}, "visible_to_adaptation": {"type": "boolean"}, "use": {"$ref": "#/$defs/text"}
      }
    },
    "evolutionEvent": {
      "type": "object", "additionalProperties": false,
      "required": ["event_id", "sequence", "object_type", "object_ref_id", "action", "trigger", "approver", "evidence_ids", "reason"],
      "properties": {
        "event_id": {"$ref": "#/$defs/id"}, "sequence": {"type": "integer", "minimum": 1},
        "object_type": {"enum": ["criterion_set", "case_assembly"]}, "object_ref_id": {"$ref": "#/$defs/id"},
        "action": {"enum": ["proposed", "rejected", "admitted", "retired", "rolled_back"]},
        "trigger": {"enum": ["refine", "add", "restructure", "coverage", "discrimination", "invalidity", "regression", "scheduled_review"]},
        "approver": {"$ref": "#/$defs/text"}, "evidence_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "reason": {"$ref": "#/$defs/text"}
      }
    },
    "evolutionBridge": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "frozen_before_cycle", "measurement_ref_id", "external_system_ref_ids", "external_judge_ref_ids", "score_bridge_evidence_ids", "decision_bridge_evidence_ids", "uncertainty_method", "cost_evidence_ids", "construct_continuity", "untouched_transport", "limitations"],
      "properties": {
        "status": {"enum": ["not_run", "failed", "passed"]}, "frozen_before_cycle": {"type": "boolean"},
        "measurement_ref_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]},
        "external_system_ref_ids": {"$ref": "#/$defs/ids"}, "external_judge_ref_ids": {"$ref": "#/$defs/ids"},
        "score_bridge_evidence_ids": {"$ref": "#/$defs/ids"}, "decision_bridge_evidence_ids": {"$ref": "#/$defs/ids"},
        "uncertainty_method": {"enum": ["not_estimated", "cluster_bootstrap", "hierarchical_model", "design_based", "exact_enumeration"]},
        "cost_evidence_ids": {"$ref": "#/$defs/ids"},
        "construct_continuity": {"enum": ["not_claimed", "unsupported", "provisional", "supported"]},
        "untouched_transport": {"enum": ["not_claimed", "unsupported", "provisional", "supported"]},
        "limitations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}}
      }
    },
    "instrumentEvolution": {
      "type": "object", "additionalProperties": false,
      "required": ["cycle_id", "from_benchmark_version", "to_benchmark_version", "from_criterion_ref_id", "to_criterion_ref_id", "from_case_assembly_ref_id", "to_case_assembly_ref_id", "raw_human_authority_evidence_ids", "typed_disagreement_evidence_ids", "history_complete", "events", "partitions", "development_system_ref_ids", "development_judge_ref_ids", "bridge", "rollback_target_ref_ids", "claim_boundary"],
      "properties": {
        "cycle_id": {"$ref": "#/$defs/id"}, "from_benchmark_version": {"$ref": "#/$defs/text"}, "to_benchmark_version": {"$ref": "#/$defs/text"},
        "from_criterion_ref_id": {"$ref": "#/$defs/id"}, "to_criterion_ref_id": {"$ref": "#/$defs/id"},
        "from_case_assembly_ref_id": {"$ref": "#/$defs/id"}, "to_case_assembly_ref_id": {"$ref": "#/$defs/id"},
        "raw_human_authority_evidence_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "typed_disagreement_evidence_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "history_complete": {"const": true}, "events": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/evolutionEvent"}},
        "partitions": {"type": "array", "minItems": 3, "items": {"$ref": "#/$defs/evolutionPartition"}},
        "development_system_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "development_judge_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "bridge": {"$ref": "#/$defs/evolutionBridge"}, "rollback_target_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "claim_boundary": {"$ref": "#/$defs/text"}
      }
    },
    "healthRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["task_health_id", "task_ref_id", "suite_ref_id", "instrument_version", "origin", "operational_roles", "reference_attempts", "contrast_set", "replication_policy", "adjudications", "health_evidence", "owner", "last_reviewed", "transitions", "revisions", "retirement", "claim_boundary"],
      "properties": {
        "task_health_id": {"$ref": "#/$defs/id"}, "task_ref_id": {"$ref": "#/$defs/id"}, "suite_ref_id": {"$ref": "#/$defs/id"}, "instrument_version": {"$ref": "#/$defs/text"},
        "origin": {"$ref": "#/$defs/origin"}, "operational_roles": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/roleAssignment"}},
        "reference_attempts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/referenceAttempt"}},
        "contrast_set": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/contrastCase"}},
        "replication_policy": {"$ref": "#/$defs/replicationPolicy"}, "adjudications": {"type": "array", "items": {"$ref": "#/$defs/adjudication"}},
        "health_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/healthSignal"}},
        "owner": {"$ref": "#/$defs/text"}, "last_reviewed": {"type": "string", "format": "date"},
        "transitions": {"type": "array", "items": {"$ref": "#/$defs/transition"}}, "revisions": {"type": "array", "items": {"$ref": "#/$defs/revision"}},
        "retirement": {"$ref": "#/$defs/retirement"}, "instrument_evolution": {"$ref": "#/$defs/instrumentEvolution"}, "claim_boundary": {"$ref": "#/$defs/text"}
      }
    }
  }
}
