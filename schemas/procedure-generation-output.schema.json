{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/procedure-generation-output.schema.json",
  "title": "Source-only procedure generation output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_id", "package_version", "source_identity", "generation_context", "proposition_bindings", "clauses", "omissions", "contradictions", "thresholds", "artifact_conventions", "failure_signatures", "claim_ceiling"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "package_id": {"$ref": "#/$defs/id"},
    "package_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "source_identity": {
      "type": "object", "additionalProperties": false,
      "required": ["family_id", "family_version", "source_corpus_sha256"],
      "properties": {
        "family_id": {"$ref": "#/$defs/id"},
        "family_version": {"$ref": "#/$defs/text"},
        "source_corpus_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "generation_context": {
      "type": "object", "additionalProperties": false,
      "required": ["generator_kind", "source_only", "task_context_visible", "generation_attempt", "visible_inputs"],
      "properties": {
        "generator_kind": {"enum": ["model_corpus_only_once", "builder_reference_source_only"]},
        "source_only": {"const": true},
        "task_context_visible": {"const": false},
        "generation_attempt": {"type": "integer", "minimum": 1},
        "visible_inputs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/path"}, "uniqueItems": true}
      }
    },
    "proposition_bindings": {
      "type": "array", "minItems": 1, "items": {
        "type": "object", "additionalProperties": false,
        "required": ["proposition_id", "clause_ids", "transformation"],
        "properties": {
          "proposition_id": {"$ref": "#/$defs/source_id"},
          "clause_ids": {"$ref": "#/$defs/id_array_nonempty"},
          "transformation": {"enum": ["verbatim", "bounded_paraphrase", "combined_synthesis"]}
        }
      }
    },
    "clauses": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/clause"}},
    "omissions": {"type": "array", "items": {"$ref": "#/$defs/omission"}},
    "contradictions": {"type": "array", "items": {"$ref": "#/$defs/primitive"}},
    "thresholds": {"type": "array", "items": {"$ref": "#/$defs/primitive"}},
    "artifact_conventions": {"type": "array", "items": {"$ref": "#/$defs/primitive"}},
    "failure_signatures": {"type": "array", "items": {"$ref": "#/$defs/primitive"}},
    "claim_ceiling": {
      "type": "object", "additionalProperties": false,
      "required": ["expert_provenance", "professional_validity", "transfer", "agent_capability", "utility", "production_fitness", "readiness"],
      "properties": {
        "expert_provenance": {"const": false},
        "professional_validity": {"const": false},
        "transfer": {"const": false},
        "agent_capability": {"const": false},
        "utility": {"const": false},
        "production_fitness": {"const": false},
        "readiness": {"const": false}
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "minLength": 1, "pattern": "^[a-z][a-z0-9._-]*$"},
    "source_id": {"type": "string", "minLength": 1, "pattern": "^[A-Za-z][A-Za-z0-9._-]*$"},
    "text": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^[^/]"},
    "id_array_nonempty": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "clause": {
      "type": "object", "additionalProperties": false,
      "required": ["clause_id", "instruction", "proposition_basis"],
      "properties": {
        "clause_id": {"$ref": "#/$defs/id"},
        "instruction": {"$ref": "#/$defs/text"},
        "proposition_basis": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source_id"}, "uniqueItems": true}
      }
    },
    "primitive": {
      "type": "object", "additionalProperties": false,
      "required": ["item_id", "source_object_id", "proposition_basis", "content"],
      "properties": {
        "item_id": {"$ref": "#/$defs/id"},
        "source_object_id": {"$ref": "#/$defs/source_id"},
        "proposition_basis": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source_id"}, "uniqueItems": true},
        "content": {"$ref": "#/$defs/text"}
      }
    },
    "omission": {
      "type": "object", "additionalProperties": false,
      "required": ["source_kind", "source_object_id", "reason_kind", "rationale"],
      "properties": {
        "source_kind": {"enum": ["contradiction", "threshold", "artifact_convention", "failure_signature"]},
        "source_object_id": {"$ref": "#/$defs/source_id"},
        "reason_kind": {"enum": ["not_applicable_to_package_scope", "unsupported_transformation", "unresolved_source_ambiguity"]},
        "rationale": {"$ref": "#/$defs/text"}
      }
    }
  }
}
