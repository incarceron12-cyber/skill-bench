{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/evidence-acquisition-episode.schema.json",
  "title": "skill-bench evidence-acquisition episode package",
  "description": "Cross-domain contract separating inquiry intent, parser interpretation, access, adoption, stopping, and terminal consequence under matched information conditions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_id", "status", "provenance", "reused_contract_refs", "conditions", "scenarios", "claim_limits"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "package_id": {"$ref": "#/$defs/id"},
    "status": {"const": "internal_synthetic_conformance_only"},
    "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}},
    "reused_contract_refs": {
      "type": "object", "additionalProperties": false,
      "required": ["task_ids", "check_ids", "grader_ids", "task_health_ids", "metric_ids", "validity_argument_ids"],
      "properties": {
        "task_ids": {"$ref": "#/$defs/ids"}, "check_ids": {"$ref": "#/$defs/ids"}, "grader_ids": {"$ref": "#/$defs/ids"},
        "task_health_ids": {"$ref": "#/$defs/ids"}, "metric_ids": {"$ref": "#/$defs/ids"}, "validity_argument_ids": {"$ref": "#/$defs/ids"}
      }
    },
    "conditions": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/condition"}},
    "scenarios": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/scenario"}},
    "claim_limits": {
      "type": "object", "additionalProperties": false, "required": ["supported", "unsupported"],
      "properties": {"supported": {"$ref": "#/$defs/texts"}, "unsupported": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}, "uniqueItems": true}}
    }
  },
  "$defs": {
    "text": {"type": "string", "minLength": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "ids": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "texts": {"type": "array", "items": {"$ref": "#/$defs/text"}, "uniqueItems": true},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "provenance": {
      "type": "object", "additionalProperties": false, "required": ["path", "sha256", "locator", "role"],
      "properties": {"path": {"$ref": "#/$defs/path"}, "sha256": {"$ref": "#/$defs/sha256"}, "locator": {"$ref": "#/$defs/text"}, "role": {"enum": ["design_evidence", "reused_contract"]}}
    },
    "condition": {
      "type": "object", "additionalProperties": false,
      "required": ["condition_id", "delivery_mode", "agent_may_request", "supply_rule", "feedback_policy"],
      "properties": {
        "condition_id": {"enum": ["active", "full_information", "expert_minimal"]},
        "delivery_mode": {"enum": ["on_request", "all_admissible_at_start", "frozen_minimal_set_at_start"]},
        "agent_may_request": {"type": "boolean"}, "supply_rule": {"$ref": "#/$defs/text"},
        "feedback_policy": {"const": "evaluator_outputs_firewalled_until_terminal"}
      }
    },
    "evidenceAtom": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "description", "provenance", "availability", "decision_value", "cost", "delay_steps", "risk", "redundancy_group", "dependency_ids", "contradicts_ids", "minimal_set_member"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/id"}, "description": {"$ref": "#/$defs/text"},
        "provenance": {"type": "object", "additionalProperties": false, "required": ["source_id", "locator", "authority", "valid_at"], "properties": {"source_id": {"$ref": "#/$defs/id"}, "locator": {"$ref": "#/$defs/text"}, "authority": {"enum": ["authoritative", "corroborating", "unverified", "conflicting"]}, "valid_at": {"type": "string", "format": "date-time"}}},
        "availability": {"enum": ["admissible", "delayed", "restricted", "unavailable"]},
        "decision_value": {"type": "number"}, "cost": {"type": "number", "minimum": 0}, "delay_steps": {"type": "integer", "minimum": 0},
        "risk": {"enum": ["none", "low", "moderate", "high"]}, "redundancy_group": {"type": ["string", "null"]},
        "dependency_ids": {"$ref": "#/$defs/ids"}, "contradicts_ids": {"$ref": "#/$defs/ids"}, "minimal_set_member": {"type": "boolean"}
      }
    },
    "parserInterpretation": {
      "type": "object", "additionalProperties": false,
      "required": ["parser_id", "status", "mapped_evidence_ids", "interpreted_scope", "confidence", "evidence_locator"],
      "properties": {
        "parser_id": {"$ref": "#/$defs/id"}, "status": {"enum": ["matched", "ambiguous", "unmatched", "parser_error"]},
        "mapped_evidence_ids": {"$ref": "#/$defs/ids"}, "interpreted_scope": {"$ref": "#/$defs/text"},
        "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1}, "evidence_locator": {"$ref": "#/$defs/text"}
      }
    },
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["request_id", "step", "raw_request", "intent", "requested_scope", "expected_value_basis", "parser_interpretation"],
      "properties": {
        "request_id": {"$ref": "#/$defs/id"}, "step": {"type": "integer", "minimum": 1}, "raw_request": {"$ref": "#/$defs/text"},
        "intent": {"$ref": "#/$defs/text"}, "requested_scope": {"$ref": "#/$defs/text"}, "expected_value_basis": {"$ref": "#/$defs/text"},
        "parser_interpretation": {"$ref": "#/$defs/parserInterpretation"}
      }
    },
    "accessEvent": {
      "type": "object", "additionalProperties": false,
      "required": ["access_event_id", "step", "request_id", "evidence_id", "status", "content_locator", "observer_id", "transformation", "reason"],
      "properties": {
        "access_event_id": {"$ref": "#/$defs/id"}, "step": {"type": "integer", "minimum": 0}, "request_id": {"type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9._-]*$"},
        "evidence_id": {"type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9._-]*$"}, "status": {"enum": ["released", "delayed", "denied", "ambiguous", "failed"]},
        "content_locator": {"type": ["string", "null"]}, "observer_id": {"$ref": "#/$defs/id"},
        "transformation": {"enum": ["none", "redacted", "summarized", "normalized"]}, "reason": {"$ref": "#/$defs/text"}
      }
    },
    "adoption": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "access_event_id", "disposition", "trace_evidence_locator", "belief_update", "action_or_artifact_change"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/id"}, "access_event_id": {"$ref": "#/$defs/id"},
        "disposition": {"enum": ["adopted", "cited_not_adopted", "rejected", "contradicted", "ignored"]},
        "trace_evidence_locator": {"$ref": "#/$defs/text"}, "belief_update": {"$ref": "#/$defs/text"}, "action_or_artifact_change": {"$ref": "#/$defs/text"}
      }
    },
    "stopping": {
      "type": "object", "additionalProperties": false,
      "required": ["step", "reason", "basis_evidence_ids", "considered_unacquired_ids", "remaining_budget", "declared_loss_rule", "uncertainty", "terminal_choice"],
      "properties": {
        "step": {"type": "integer", "minimum": 0}, "reason": {"enum": ["decision_sufficient", "marginal_value_below_cost", "budget_exhausted", "all_supplied", "expert_minimal_set_supplied", "abstain", "escalate", "environment_failure"]},
        "basis_evidence_ids": {"$ref": "#/$defs/ids"}, "considered_unacquired_ids": {"$ref": "#/$defs/ids"}, "remaining_budget": {"type": "number", "minimum": 0},
        "declared_loss_rule": {"$ref": "#/$defs/text"}, "uncertainty": {"$ref": "#/$defs/text"}, "terminal_choice": {"enum": ["act", "artifact", "abstain", "escalate"]}
      }
    },
    "terminalConsequence": {
      "type": "object", "additionalProperties": false,
      "required": ["action_or_artifact", "endpoint_evidence_locators", "decision_loss", "severe_omissions", "resource_cost", "claim_scope"],
      "properties": {
        "action_or_artifact": {"$ref": "#/$defs/text"}, "endpoint_evidence_locators": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
        "decision_loss": {"type": "number", "minimum": 0}, "severe_omissions": {"$ref": "#/$defs/ids"}, "resource_cost": {"type": "number", "minimum": 0},
        "claim_scope": {"const": "synthetic_instrument_behavior_only"}
      }
    },
    "episode": {
      "type": "object", "additionalProperties": false,
      "required": ["episode_id", "condition_id", "requests", "access_events", "adoptions", "feedback_firewall", "stopping", "terminal_consequence"],
      "properties": {
        "episode_id": {"$ref": "#/$defs/id"}, "condition_id": {"enum": ["active", "full_information", "expert_minimal"]},
        "requests": {"type": "array", "items": {"$ref": "#/$defs/request"}}, "access_events": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/accessEvent"}},
        "adoptions": {"type": "array", "items": {"$ref": "#/$defs/adoption"}},
        "feedback_firewall": {
          "type": "object", "additionalProperties": false, "required": ["evaluator_outputs_exposed_before_terminal", "allowed_preterminal_feedback", "feedback_events"],
          "properties": {
            "evaluator_outputs_exposed_before_terminal": {"const": false}, "allowed_preterminal_feedback": {"type": "array", "items": {"enum": ["access_status", "evidence_content", "budget_state"]}, "uniqueItems": true},
            "feedback_events": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["source", "phase", "content_kind"], "properties": {"source": {"enum": ["environment", "evaluator", "grader"]}, "phase": {"enum": ["preterminal", "post_terminal"]}, "content_kind": {"$ref": "#/$defs/text"}}}}
          }
        },
        "stopping": {"$ref": "#/$defs/stopping"}, "terminal_consequence": {"$ref": "#/$defs/terminalConsequence"}
      }
    },
    "scenario": {
      "type": "object", "additionalProperties": false,
      "required": ["scenario_id", "work_shape", "task_ref_id", "frozen_target", "evidence_atoms", "episodes"],
      "properties": {
        "scenario_id": {"$ref": "#/$defs/id"}, "work_shape": {"$ref": "#/$defs/text"}, "task_ref_id": {"$ref": "#/$defs/id"}, "frozen_target": {"$ref": "#/$defs/text"},
        "evidence_atoms": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/evidenceAtom"}},
        "episodes": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/episode"}}
      }
    }
  }
}
