{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/benchmark-bundle.schema.json",
  "title": "skill-bench benchmark bundle",
  "description": "Executable contract joining a knowledge-work task, independently versioned procedural skills and rubrics, graders, trials, artifacts, traces, rubric checks, and causal failure labels.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "benchmark_version", "procedural_skills", "rubrics", "task", "graders", "trials"],
  "properties": {
    "schema_version": {"const": "0.2.0"},
    "benchmark_version": {"$ref": "#/$defs/nonEmpty"},
    "procedural_skills": {"type": "array", "items": {"$ref": "#/$defs/proceduralSkill"}},
    "rubrics": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/rubric"}},
    "task": {"$ref": "#/$defs/task"},
    "graders": {"type": "array", "items": {"$ref": "#/$defs/grader"}},
    "trials": {"type": "array", "items": {"$ref": "#/$defs/trial"}}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "identifier": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "visibility": {"enum": ["public", "private", "hidden", "internal_calibration"]},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "versionedComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_id", "version", "sha256"],
      "properties": {
        "component_id": {"$ref": "#/$defs/identifier"},
        "version": {"$ref": "#/$defs/nonEmpty"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "locator", "description"],
      "properties": {
        "source_type": {"enum": ["primary_source", "expert_elicitation", "benchmark_review", "synthetic", "derived"]},
        "locator": {"$ref": "#/$defs/nonEmpty"},
        "local_path": {"$ref": "#/$defs/relativePath"},
        "section_or_pages": {"type": "string"},
        "description": {"$ref": "#/$defs/nonEmpty"},
        "derivation": {"type": "string"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "path", "media_type", "visibility", "trust_rank", "provenance"],
      "properties": {
        "source_id": {"$ref": "#/$defs/identifier"},
        "path": {"$ref": "#/$defs/relativePath"},
        "media_type": {"$ref": "#/$defs/nonEmpty"},
        "visibility": {"$ref": "#/$defs/visibility"},
        "trust_rank": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "valid_as_of": {"type": "string", "format": "date"},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "primitive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primitive_id", "kind", "description", "visibility", "source_ids", "check_ids", "provenance"],
      "properties": {
        "primitive_id": {"$ref": "#/$defs/identifier"},
        "kind": {"enum": ["hidden_requirement", "trusted_evidence_rule", "contradiction", "expert_caveat", "decision_threshold", "artifact_convention", "stakeholder_preference", "polished_but_wrong_trap", "safety_compliance_constraint"]},
        "description": {"$ref": "#/$defs/nonEmpty"},
        "visibility": {"$ref": "#/$defs/visibility"},
        "source_ids": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "check_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "artifactContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "path", "media_type", "required", "acceptance_criteria"],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/identifier"},
        "path": {"$ref": "#/$defs/relativePath"},
        "media_type": {"$ref": "#/$defs/nonEmpty"},
        "required": {"type": "boolean"},
        "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}},
        "machine_inspectable": {"type": "boolean", "default": false}
      }
    },
    "proceduralRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "phase_id", "public_basis", "ordering_after", "observable_event_kinds", "artifact_ids", "check_ids", "failure_signatures", "provenance"],
      "properties": {
        "requirement_id": {"$ref": "#/$defs/identifier"},
        "phase_id": {"$ref": "#/$defs/identifier"},
        "public_basis": {"$ref": "#/$defs/nonEmpty"},
        "ordering_after": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "observable_event_kinds": {"type": "array", "minItems": 1, "items": {"enum": ["observation", "tool_call", "tool_result", "artifact_write", "checkpoint", "error", "verifier_feedback", "repair", "verification"]}, "uniqueItems": true},
        "artifact_ids": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "check_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "failure_signatures": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "proceduralSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skill_id", "version", "sha256", "visibility", "content_path", "workflow_phases", "requirements", "provenance"],
      "properties": {
        "skill_id": {"$ref": "#/$defs/identifier"},
        "version": {"$ref": "#/$defs/nonEmpty"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "visibility": {"const": "public"},
        "content_path": {"$ref": "#/$defs/relativePath"},
        "workflow_phases": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "requirements": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/proceduralRequirement"}},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rubric_id", "version", "sha256", "relationship_to_skill", "check_ids", "provenance"],
      "properties": {
        "rubric_id": {"$ref": "#/$defs/identifier"},
        "version": {"$ref": "#/$defs/nonEmpty"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "relationship_to_skill": {"enum": ["independent", "shared_expert_model", "exact_disclosed"]},
        "check_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "rootCauseLabel": {
      "enum": ["source_discovery_failure", "evidence_reconciliation_failure", "calculation_failure", "artifact_structure_failure", "artifact_format_failure", "stakeholder_judgment_failure", "presentation_failure", "tool_use_failure", "context_management_failure", "instruction_following_failure", "safety_or_compliance_failure", "ambiguous_task_design", "environment_or_grader_failure", "unknown"]
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "description", "rubric_id", "grader_id", "kind", "visibility", "boundary_disclosure", "public_basis_requirement_ids", "weight", "artifact_ids", "evidence_source_ids", "pass_criteria", "fail_criteria", "allowed_root_causes", "provenance"],
      "properties": {
        "check_id": {"$ref": "#/$defs/identifier"},
        "description": {"$ref": "#/$defs/nonEmpty"},
        "rubric_id": {"$ref": "#/$defs/identifier"},
        "grader_id": {"$ref": "#/$defs/identifier"},
        "kind": {"enum": ["deterministic", "spreadsheet", "state", "llm_judge", "human_judge", "pairwise"]},
        "visibility": {"$ref": "#/$defs/visibility"},
        "boundary_disclosure": {"enum": ["exact_disclosed", "public_principle_only", "held_out_consequence"]},
        "public_basis_requirement_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "weight": {"type": "number", "exclusiveMinimum": 0},
        "artifact_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "evidence_source_ids": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "pass_criteria": {"$ref": "#/$defs/nonEmpty"},
        "fail_criteria": {"$ref": "#/$defs/nonEmpty"},
        "allowed_root_causes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/rootCauseLabel"}, "uniqueItems": true},
        "safety_critical": {"type": "boolean", "default": false},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "version", "title", "domain", "role", "stakeholder", "decision", "objective", "source_pack", "domain_primitives", "artifact_contracts", "checks", "policies", "provenance"],
      "properties": {
        "task_id": {"$ref": "#/$defs/identifier"},
        "version": {"$ref": "#/$defs/nonEmpty"},
        "title": {"$ref": "#/$defs/nonEmpty"},
        "domain": {"$ref": "#/$defs/nonEmpty"},
        "role": {"$ref": "#/$defs/nonEmpty"},
        "stakeholder": {"$ref": "#/$defs/nonEmpty"},
        "decision": {"$ref": "#/$defs/nonEmpty"},
        "objective": {"$ref": "#/$defs/nonEmpty"},
        "source_pack": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}},
        "domain_primitives": {"type": "array", "items": {"$ref": "#/$defs/primitive"}},
        "artifact_contracts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifactContract"}},
        "checks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/check"}},
        "difficulty": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expected_band", "drivers"],
          "properties": {
            "expected_band": {"enum": ["easy", "mid", "hard", "frontier"]},
            "drivers": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}},
            "editable_knobs": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}}
          }
        },
        "policies": {
          "type": "object",
          "additionalProperties": false,
          "required": ["network", "memory", "retries", "allowed_tools"],
          "properties": {
            "network": {"enum": ["allowed", "denied", "allowlist"]},
            "memory": {"enum": ["allowed", "denied", "task_scoped"]},
            "retries": {"type": "integer", "minimum": 0},
            "allowed_tools": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}, "uniqueItems": true}
          }
        },
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "grader": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grader_id", "version", "sha256", "kind", "implementation", "input_contract", "output_contract"],
      "properties": {
        "grader_id": {"$ref": "#/$defs/identifier"},
        "version": {"$ref": "#/$defs/nonEmpty"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "kind": {"enum": ["deterministic", "spreadsheet", "state", "llm_judge", "human_judge", "pairwise"]},
        "implementation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entrypoint"],
          "properties": {
            "entrypoint": {"$ref": "#/$defs/nonEmpty"},
            "config_path": {"$ref": "#/$defs/relativePath"},
            "model": {"type": "string"},
            "model_version": {"type": "string"},
            "prompt_version": {"type": "string"},
            "prompt_sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "input_contract": {"type": "array", "minItems": 1, "items": {"enum": ["task", "sources", "artifacts", "trace", "reference", "human_pair"]}, "uniqueItems": true},
        "output_contract": {"const": "check-result-v0.1"},
        "provenance": {"type": "array", "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "agentConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "scaffold", "skills_enabled", "tool_policy", "memory_policy"],
      "properties": {
        "model": {"$ref": "#/$defs/nonEmpty"},
        "scaffold": {"$ref": "#/$defs/nonEmpty"},
        "skills_enabled": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}},
        "tool_policy": {"$ref": "#/$defs/nonEmpty"},
        "memory_policy": {"$ref": "#/$defs/nonEmpty"}
      }
    },
    "observedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "path", "media_type", "sha256", "bytes"],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/identifier"},
        "path": {"$ref": "#/$defs/relativePath"},
        "media_type": {"$ref": "#/$defs/nonEmpty"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "bytes": {"type": "integer", "minimum": 0}
      }
    },
    "traceEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_id", "sequence", "timestamp", "actor", "kind", "summary"],
      "properties": {
        "event_id": {"$ref": "#/$defs/identifier"},
        "sequence": {"type": "integer", "minimum": 0},
        "timestamp": {"type": "string", "format": "date-time"},
        "actor": {"enum": ["agent", "tool", "environment", "grader", "human"]},
        "kind": {"enum": ["observation", "reasoning_summary", "tool_call", "tool_result", "artifact_write", "checkpoint", "error", "verifier_feedback", "repair", "verification", "grader_decision"]},
        "summary": {"$ref": "#/$defs/nonEmpty"},
        "tool_name": {"type": "string"},
        "artifact_ids": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "source_ids": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "payload_path": {"$ref": "#/$defs/relativePath"},
        "diagnostic_code": {"type": "string"},
        "feedback_specificity": {"enum": ["structured_actionable", "actionable", "ambiguous", "non_actionable"]},
        "feedback_visibility": {"enum": ["agent_visible", "grader_only"]},
        "recommended_next_action": {"type": "string"},
        "verification_outcome": {"enum": ["passed", "failed", "inconclusive"]}
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "verifier_feedback"}}, "required": ["kind"]},
          "then": {"required": ["diagnostic_code", "feedback_specificity", "feedback_visibility"]}
        },
        {
          "if": {"properties": {"kind": {"const": "verification"}}, "required": ["kind"]},
          "then": {"required": ["verification_outcome"]}
        }
      ]
    },
    "traceEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_event_id", "to_event_id", "relation"],
      "properties": {
        "from_event_id": {"$ref": "#/$defs/identifier"},
        "to_event_id": {"$ref": "#/$defs/identifier"},
        "relation": {"enum": ["control", "data", "artifact", "evidence", "retry", "error_feedback", "feedback_repair", "repair_verification"]}
      }
    },
    "evaluationVersions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "task", "skill", "rubric", "graders", "tool_interface", "harness", "feedback_policy"],
      "properties": {
        "condition": {"enum": ["no_skill_independent_rubric", "no_skill_shared_rubric", "public_skill_independent_rubric", "public_skill_shared_rubric", "exact_rubric_disclosed"]},
        "task": {"$ref": "#/$defs/versionedComponent"},
        "skill": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/versionedComponent"}]},
        "rubric": {"$ref": "#/$defs/versionedComponent"},
        "graders": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/versionedComponent"}},
        "tool_interface": {"$ref": "#/$defs/versionedComponent"},
        "harness": {"$ref": "#/$defs/versionedComponent"},
        "feedback_policy": {"$ref": "#/$defs/versionedComponent"}
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "events", "dependencies"],
      "properties": {
        "trace_id": {"$ref": "#/$defs/identifier"},
        "events": {"type": "array", "items": {"$ref": "#/$defs/traceEvent"}},
        "dependencies": {"type": "array", "items": {"$ref": "#/$defs/traceEdge"}}
      }
    },
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "grader_id", "outcome", "score", "rationale", "evidence"],
      "properties": {
        "check_id": {"$ref": "#/$defs/identifier"},
        "grader_id": {"$ref": "#/$defs/identifier"},
        "outcome": {"enum": ["passed", "failed", "error", "not_run"]},
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "rationale": {"$ref": "#/$defs/nonEmpty"},
        "evidence": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}},
        "root_cause": {"$ref": "#/$defs/rootCauseLabel"},
        "surfaced_at_event_id": {"$ref": "#/$defs/identifier"},
        "root_event_id": {"$ref": "#/$defs/identifier"},
        "causal_slice_event_ids": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true}
      },
      "allOf": [
        {
          "if": {"properties": {"outcome": {"enum": ["failed", "error"]}}, "required": ["outcome"]},
          "then": {"required": ["root_cause", "surfaced_at_event_id", "root_event_id", "causal_slice_event_ids"]}
        },
        {
          "if": {"properties": {"outcome": {"const": "passed"}}, "required": ["outcome"]},
          "then": {"properties": {"score": {"const": 1}}}
        }
      ]
    },
    "trial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trial_id", "task_id", "task_version", "status", "started_at", "agent", "evaluation_versions", "artifacts", "trace", "check_results"],
      "properties": {
        "trial_id": {"$ref": "#/$defs/identifier"},
        "task_id": {"$ref": "#/$defs/identifier"},
        "task_version": {"$ref": "#/$defs/nonEmpty"},
        "status": {"enum": ["running", "completed", "aborted", "environment_error"]},
        "started_at": {"type": "string", "format": "date-time"},
        "ended_at": {"type": "string", "format": "date-time"},
        "agent": {"$ref": "#/$defs/agentConfig"},
        "evaluation_versions": {"$ref": "#/$defs/evaluationVersions"},
        "artifacts": {"type": "array", "items": {"$ref": "#/$defs/observedArtifact"}},
        "trace": {"$ref": "#/$defs/trace"},
        "check_results": {"type": "array", "items": {"$ref": "#/$defs/checkResult"}},
        "aggregate_score": {"type": "number", "minimum": 0, "maximum": 1},
        "cost_usd": {"type": "number", "minimum": 0},
        "duration_seconds": {"type": "number", "minimum": 0},
        "failure_postmortem_path": {"$ref": "#/$defs/relativePath"}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "completed"}}, "required": ["status"]},
          "then": {"required": ["ended_at", "aggregate_score", "duration_seconds"]}
        }
      ]
    }
  }
}
