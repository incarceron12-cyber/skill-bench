{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/ablation-preflight.schema.json",
  "title": "Matched ablation task-only preflight",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_kind", "capability_evidence", "bundle_source", "fixture_source", "components", "conditions", "matched_controls", "limitations"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "run_kind": {"const": "task_only_fixture_replay"},
    "capability_evidence": {"const": false},
    "bundle_source": {"$ref": "#/$defs/fileRef"},
    "fixture_source": {
      "type": "object", "additionalProperties": false,
      "required": ["authorship", "matrix", "memo"],
      "properties": {
        "authorship": {"const": "builder_authored_calibration_fixture_not_agent_output"},
        "matrix": {"$ref": "#/$defs/fileRef"},
        "memo": {"$ref": "#/$defs/fileRef"}
      }
    },
    "components": {
      "type": "object", "additionalProperties": false,
      "required": ["task", "skill", "independent_rubric", "shared_rubric", "tool_interface", "harness", "feedback_policy"],
      "properties": {
        "task": {"$ref": "#/$defs/component"},
        "skill": {"$ref": "#/$defs/component"},
        "independent_rubric": {"$ref": "#/$defs/component"},
        "shared_rubric": {"$ref": "#/$defs/component"},
        "tool_interface": {"$ref": "#/$defs/component"},
        "harness": {"$ref": "#/$defs/component"},
        "feedback_policy": {"$ref": "#/$defs/component"}
      }
    },
    "conditions": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"$ref": "#/$defs/condition"}
    },
    "matched_controls": {
      "type": "object", "additionalProperties": false,
      "required": ["same_task_hash", "same_fixture_hashes", "same_tool_hash", "same_harness_hash", "same_feedback_policy_hash", "only_treatments"],
      "properties": {
        "same_task_hash": {"const": true},
        "same_fixture_hashes": {"const": true},
        "same_tool_hash": {"const": true},
        "same_harness_hash": {"const": true},
        "same_feedback_policy_hash": {"const": true},
        "only_treatments": {"const": ["procedural_skill_visibility", "rubric_relationship"]}
      }
    },
    "limitations": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "fileRef": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "bytes"],
      "properties": {"path": {"$ref": "#/$defs/path"}, "sha256": {"$ref": "#/$defs/sha256"}, "bytes": {"type": "integer", "minimum": 1}}
    },
    "component": {
      "type": "object", "additionalProperties": false,
      "required": ["component_id", "version", "sha256", "path"],
      "properties": {
        "component_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
        "version": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "path": {"$ref": "#/$defs/path"}
      }
    },
    "graderRun": {
      "type": "object", "additionalProperties": false,
      "required": ["grader_id", "result_path", "result_sha256", "outcomes"],
      "properties": {
        "grader_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
        "result_path": {"$ref": "#/$defs/path"},
        "result_sha256": {"$ref": "#/$defs/sha256"},
        "outcomes": {"type": "object", "minProperties": 1, "additionalProperties": {"enum": ["passed", "failed", "error", "not_run"]}}
      }
    },
    "condition": {
      "type": "object", "additionalProperties": false,
      "required": ["condition_id", "skill", "rubric", "matrix", "memo", "grader_runs", "unexecuted_checks", "interpretation"],
      "properties": {
        "condition_id": {"enum": ["no_skill_independent_rubric", "no_skill_shared_rubric", "public_skill_independent_rubric", "public_skill_shared_rubric"]},
        "skill": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/component"}]},
        "rubric": {"$ref": "#/$defs/component"},
        "matrix": {"$ref": "#/$defs/fileRef"},
        "memo": {"$ref": "#/$defs/fileRef"},
        "grader_runs": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/graderRun"}},
        "unexecuted_checks": {"type": "array", "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"}, "uniqueItems": true},
        "interpretation": {"const": "plumbing_preflight_only_no_condition_effect"}
      }
    }
  }
}
