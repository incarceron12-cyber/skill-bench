{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/plural-judgment.schema.json",
  "title": "Plural judgment and policy aggregation conformance package",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_id", "scope_limits", "provenance", "frameworks", "observers", "evidence_views", "observations", "disagreement_cases", "aggregations", "claim_limits"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "package_id": {"$ref": "#/$defs/id"},
    "scope_limits": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
    "provenance": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["source_id", "path", "locator", "role"], "properties": {"source_id": {"$ref": "#/$defs/id"}, "path": {"$ref": "#/$defs/path"}, "locator": {"$ref": "#/$defs/text"}, "role": {"enum": ["design_evidence", "internal_calibration"]}}}},
    "frameworks": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["framework_id", "label", "declaration_status", "declared_before_observation", "source_ref", "scope", "threshold_rule", "stability_evidence"], "properties": {"framework_id": {"$ref": "#/$defs/id"}, "label": {"$ref": "#/$defs/text"}, "declaration_status": {"enum": ["declared", "elicited", "analyst_inferred"]}, "declared_before_observation": {"type": "boolean"}, "source_ref": {"$ref": "#/$defs/text"}, "scope": {"$ref": "#/$defs/text"}, "threshold_rule": {"$ref": "#/$defs/text"}, "stability_evidence": {"$ref": "#/$defs/text"}}}},
    "observers": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["observer_id", "authority", "independent_of", "framework_id"], "properties": {"observer_id": {"$ref": "#/$defs/id"}, "authority": {"$ref": "#/$defs/text"}, "independent_of": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "framework_id": {"$ref": "#/$defs/id"}}}},
    "evidence_views": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["view_id", "available_evidence", "missing_context"], "properties": {"view_id": {"$ref": "#/$defs/id"}, "available_evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}}, "missing_context": {"type": "array", "items": {"$ref": "#/$defs/text"}}}}},
    "observations": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["observation_id", "case_id", "observer_id", "framework_id", "view_id", "repeat_of", "value", "rationale", "uncertainty", "endorsed"], "properties": {"observation_id": {"$ref": "#/$defs/id"}, "case_id": {"$ref": "#/$defs/id"}, "observer_id": {"$ref": "#/$defs/id"}, "framework_id": {"$ref": "#/$defs/id"}, "view_id": {"$ref": "#/$defs/id"}, "repeat_of": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]}, "value": {"type": "number"}, "rationale": {"$ref": "#/$defs/text"}, "uncertainty": {"type": "number", "minimum": 0, "maximum": 1}, "endorsed": {"type": "boolean"}}}},
    "disagreement_cases": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["case_id", "observation_ids", "tested_reducibility", "disposition", "rationale"], "properties": {"case_id": {"$ref": "#/$defs/id"}, "observation_ids": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "tested_reducibility": {"type": "array", "items": {"enum": ["evidence_sufficiency", "rubric_comprehension", "within_rater_repeat", "prospective_framework", "multiple_observers_per_framework", "held_out_framework_interaction", "alternate_context_or_rubric", "outcome_or_stakeholder_evidence"]}, "uniqueItems": true}, "disposition": {"enum": ["resolved_evidence_gap", "resolved_specification_error", "resolved_rater_instability", "framework_stratified", "policy_selected_with_dissent", "unresolved_systematic_disagreement", "irreducible_disagreement"]}, "rationale": {"$ref": "#/$defs/text"}}}},
    "aggregations": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["aggregation_id", "case_id", "observation_ids", "intended_use", "stakeholders", "rule", "weights", "loss_basis", "output", "endorsed_by", "dissent_observation_ids", "excluded_interpretations"], "properties": {"aggregation_id": {"$ref": "#/$defs/id"}, "case_id": {"$ref": "#/$defs/id"}, "observation_ids": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "intended_use": {"$ref": "#/$defs/text"}, "stakeholders": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}}, "rule": {"$ref": "#/$defs/text"}, "weights": {"type": "object", "additionalProperties": {"type": "number", "minimum": 0}}, "loss_basis": {"$ref": "#/$defs/text"}, "output": {"type": "number"}, "endorsed_by": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "dissent_observation_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "excluded_interpretations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}}}}},
    "claim_limits": {"type": "object", "additionalProperties": false, "required": ["supported", "unsupported"], "properties": {"supported": {"type": "array", "items": {"$ref": "#/$defs/text"}}, "unsupported": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}}}}
  },
  "$defs": {"id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"}, "text": {"type": "string", "minLength": 1}, "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*\\.\\.).+$"}}
}
