{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/validity-argument.schema.json",
  "title": "skill-bench claim-centered validity argument package",
  "description": "Versioned arguments that bind immutable instruments and measurements to bounded criterion, construct, or decision claims without treating validity as a scalar benchmark property.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_id", "version", "artifacts", "evidence", "arguments"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "package_id": {"$ref": "#/$defs/id"},
    "version": {"$ref": "#/$defs/text"},
    "artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifact"}},
    "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
    "arguments": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/argument"}}
  },
  "$defs": {
    "text": {"type": "string", "minLength": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "ids": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "facetName": {"enum": ["content", "criterion", "construct", "external", "consequential"]},
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "artifact_type", "path", "version", "sha256"],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/id"},
        "artifact_type": {"enum": ["task", "bundle", "rubric", "grader", "harness", "environment", "trial", "measurement", "adjudication", "impact_record"]},
        "path": {"$ref": "#/$defs/path"},
        "version": {"$ref": "#/$defs/text"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "evidence_type", "artifact_ref_id", "locator", "description", "facet_scope", "claim_scope", "limitations", "reviewer"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/id"},
        "evidence_type": {"enum": ["deterministic_check", "trial_observation", "expert_review", "human_adjudication", "reliability_study", "transfer_study", "impact_audit", "synthetic_calibration"]},
        "artifact_ref_id": {"$ref": "#/$defs/id"},
        "locator": {"$ref": "#/$defs/text"},
        "description": {"$ref": "#/$defs/text"},
        "facet_scope": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/facetName"}, "uniqueItems": true},
        "claim_scope": {"$ref": "#/$defs/ids"},
        "limitations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
        "reviewer": {"$ref": "#/$defs/text"}
      }
    },
    "context": {
      "type": "object", "additionalProperties": false,
      "required": ["configured_system_population", "task_domain_population", "environment_tools", "time_window"],
      "properties": {
        "configured_system_population": {"$ref": "#/$defs/text"},
        "task_domain_population": {"$ref": "#/$defs/text"},
        "environment_tools": {"$ref": "#/$defs/text"},
        "time_window": {"$ref": "#/$defs/text"}
      }
    },
    "assumption": {
      "type": "object", "additionalProperties": false,
      "required": ["assumption_id", "text", "status", "evidence_ids"],
      "properties": {
        "assumption_id": {"$ref": "#/$defs/id"}, "text": {"$ref": "#/$defs/text"},
        "status": {"enum": ["supported", "contested", "untested", "rejected"]}, "evidence_ids": {"$ref": "#/$defs/ids"}
      }
    },
    "rebuttal": {
      "type": "object", "additionalProperties": false,
      "required": ["rebuttal_id", "text", "status", "evidence_ids", "response"],
      "properties": {
        "rebuttal_id": {"$ref": "#/$defs/id"}, "text": {"$ref": "#/$defs/text"},
        "status": {"enum": ["open", "mitigated", "refuted", "accepted_limit"]}, "evidence_ids": {"$ref": "#/$defs/ids"},
        "response": {"$ref": "#/$defs/text"}
      }
    },
    "facet": {
      "type": "object", "additionalProperties": false,
      "required": ["facet", "requirement", "status", "evidence_ids", "unresolved_evidence", "rationale"],
      "properties": {
        "facet": {"$ref": "#/$defs/facetName"},
        "requirement": {"enum": ["required", "trivially_satisfied_for_exact_relation", "not_applicable"]},
        "status": {"enum": ["supported", "unsupported", "unknown"]},
        "evidence_ids": {"$ref": "#/$defs/ids"},
        "unresolved_evidence": {"type": "array", "items": {"$ref": "#/$defs/text"}},
        "rationale": {"$ref": "#/$defs/text"}
      }
    },
    "nomologicalLink": {
      "type": "object", "additionalProperties": false,
      "required": ["from", "relation", "to", "evidence_ids"],
      "properties": {"from": {"$ref": "#/$defs/text"}, "relation": {"$ref": "#/$defs/text"}, "to": {"$ref": "#/$defs/text"}, "evidence_ids": {"$ref": "#/$defs/ids"}}
    },
    "decisionPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["action", "threshold", "threshold_basis", "loss_basis", "risk_tolerance", "residual_risk", "mitigations"],
      "properties": {
        "action": {"$ref": "#/$defs/text"}, "threshold": {"$ref": "#/$defs/text"},
        "threshold_basis": {"enum": ["empirical_loss_study", "expert_standard_setting", "provisional_policy", "none"]},
        "loss_basis": {"$ref": "#/$defs/text"}, "risk_tolerance": {"$ref": "#/$defs/text"}, "residual_risk": {"$ref": "#/$defs/text"},
        "mitigations": {"type": "array", "items": {"$ref": "#/$defs/text"}}
      }
    },
    "argument": {
      "type": "object", "additionalProperties": false,
      "required": ["argument_id", "version", "instrument_ref_ids", "measurement_ref_ids", "evaluation_context", "claim", "inference", "validity_facets", "status", "owners", "independent_review_evidence_ids", "reassessment_triggers", "review_by"],
      "properties": {
        "argument_id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/text"},
        "instrument_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "measurement_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
        "evaluation_context": {"$ref": "#/$defs/context"},
        "claim": {
          "type": "object", "additionalProperties": false,
          "required": ["object_type", "statement", "object_definition", "intended_interpretation", "intended_use", "stakeholders", "excluded_interpretations", "generalization_boundary"],
          "properties": {
            "object_type": {"enum": ["criterion", "construct", "decision"]}, "statement": {"$ref": "#/$defs/text"},
            "object_definition": {"$ref": "#/$defs/text"}, "intended_interpretation": {"$ref": "#/$defs/text"}, "intended_use": {"$ref": "#/$defs/text"},
            "stakeholders": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
            "excluded_interpretations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
            "generalization_boundary": {"$ref": "#/$defs/text"}
          }
        },
        "inference": {
          "type": "object", "additionalProperties": false,
          "required": ["warrant", "evidence_ids", "assumptions", "rebuttals", "mediating_constructs", "nomological_links"],
          "properties": {
            "warrant": {"$ref": "#/$defs/text"}, "evidence_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
            "assumptions": {"type": "array", "items": {"$ref": "#/$defs/assumption"}}, "rebuttals": {"type": "array", "items": {"$ref": "#/$defs/rebuttal"}},
            "mediating_constructs": {"type": "array", "items": {"$ref": "#/$defs/text"}}, "nomological_links": {"type": "array", "items": {"$ref": "#/$defs/nomologicalLink"}}
          }
        },
        "validity_facets": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"$ref": "#/$defs/facet"}},
        "decision_policy": {"$ref": "#/$defs/decisionPolicy"},
        "status": {"enum": ["supported", "provisional", "unsupported", "superseded"]},
        "owners": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
        "independent_review_evidence_ids": {"$ref": "#/$defs/ids"},
        "reassessment_triggers": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}},
        "review_by": {"type": "string", "format": "date"}
      }
    }
  }
}
