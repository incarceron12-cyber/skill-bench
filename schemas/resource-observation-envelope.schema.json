{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/resource-observation-envelope.schema.json",
  "title": "Generic cross-resource observation and commit envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["fixture_status"],
  "oneOf": [
    {"required": ["task_resource_envelope", "trial_resource_envelope"]},
    {"required": ["dependency_topology_instrument", "dependency_topology_observation"]}
  ],
  "properties": {
    "fixture_status": {"const": "internal_synthetic_contract_calibration_only"},
    "task_resource_envelope": {"$ref": "#/$defs/instrument"},
    "trial_resource_envelope": {"$ref": "#/$defs/observation"},
    "dependency_topology_instrument": {"$ref": "#/$defs/dependencyTopologyInstrument"},
    "dependency_topology_observation": {"$ref": "#/$defs/dependencyTopologyObservation"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "text": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["source_type", "locator", "description"],
      "properties": {
        "source_type": {"enum": ["primary_source", "benchmark_review", "synthetic", "derived"]},
        "locator": {"$ref": "#/$defs/text"}, "local_path": {"$ref": "#/$defs/text"},
        "section_or_pages": {"type": "string"}, "description": {"$ref": "#/$defs/text"}
      }
    },
    "instrument": {
      "type": "object", "additionalProperties": false,
      "required": ["instrument_id", "version", "parent", "session_id", "operations", "resources", "observer", "attempt_policy", "commit_policy", "claim_boundaries", "provenance"],
      "properties": {
        "instrument_id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/text"}, "session_id": {"$ref": "#/$defs/id"},
        "parent": {"type": "object", "additionalProperties": false, "required": ["state_root_sha256", "schema_version", "application_version", "start_boundary", "concurrent_writer_policy"], "properties": {
          "state_root_sha256": {"$ref": "#/$defs/sha256"}, "schema_version": {"$ref": "#/$defs/text"}, "application_version": {"$ref": "#/$defs/text"}, "start_boundary": {"$ref": "#/$defs/text"},
          "concurrent_writer_policy": {"enum": ["prohibited_and_attested", "detect_and_invalidate", "allowed_with_snapshot_isolation"]}
        }},
        "operations": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["operation_id", "sequence", "depends_on"], "properties": {
          "operation_id": {"$ref": "#/$defs/id"}, "sequence": {"type": "integer", "minimum": 1}, "depends_on": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}
        }}},
        "resources": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["resource_id", "kind", "locator", "interception", "regions", "canaries", "provenance"], "properties": {
          "resource_id": {"$ref": "#/$defs/id"}, "kind": {"enum": ["structured_table", "file_blob", "cache_queue", "sequence", "external_service"]}, "locator": {"$ref": "#/$defs/text"},
          "interception": {"enum": ["intercepted", "excluded", "unsupported", "unobserved"]},
          "regions": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["region_id", "expectation"], "properties": {"region_id": {"$ref": "#/$defs/id"}, "expectation": {"enum": ["required", "forbidden", "preserved", "unobserved"]}}}},
          "canaries": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["canary_id", "path", "expected", "fail_closed"], "properties": {"canary_id": {"$ref": "#/$defs/id"}, "path": {"enum": ["foreground", "background"]}, "expected": {"enum": ["intercepted", "blocked"]}, "fail_closed": {"const": true}}}},
          "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
        }}},
        "observer": {"type": "object", "additionalProperties": false, "required": ["component", "read_set", "exclusions", "accepted_alternatives", "ambiguity_policy"], "properties": {
          "component": {"type": "object", "additionalProperties": false, "required": ["component_id", "version", "sha256"], "properties": {"component_id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/text"}, "sha256": {"$ref": "#/$defs/sha256"}}},
          "read_set": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/resourceRegionRef"}},
          "exclusions": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["resource_id", "region_id", "reason"], "properties": {"resource_id": {"$ref": "#/$defs/id"}, "region_id": {"$ref": "#/$defs/id"}, "reason": {"$ref": "#/$defs/text"}}}},
          "accepted_alternatives": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["alternative_id", "resource_id", "item_key", "status"], "properties": {"alternative_id": {"$ref": "#/$defs/id"}, "resource_id": {"$ref": "#/$defs/id"}, "item_key": {"$ref": "#/$defs/text"}, "status": {"enum": ["accepted", "provisional"]}}}},
          "ambiguity_policy": {"const": "fail_closed_insufficient_evidence"}
        }},
        "attempt_policy": {"type": "object", "additionalProperties": false, "required": ["include_all_attempts", "failed_disposition", "invalid_disposition"], "properties": {"include_all_attempts": {"const": true}, "failed_disposition": {"const": "failed_attempt"}, "invalid_disposition": {"const": "invalid_attempt"}}},
        "commit_policy": {"type": "object", "additionalProperties": false, "required": ["default", "authorization_required", "dependency_closure_required", "stale_base", "rollback_required"], "properties": {"default": {"const": "discard"}, "authorization_required": {"const": true}, "dependency_closure_required": {"const": true}, "stale_base": {"const": "reject"}, "rollback_required": {"const": true}}},
        "claim_boundaries": {"type": "object", "additionalProperties": false, "required": ["complete_isolation", "workflow_correctness", "causal_repair", "capability_evidence", "professional_validity", "safety", "production_fitness", "readiness_evidence"], "properties": {
          "complete_isolation": {"const": false}, "workflow_correctness": {"const": false}, "causal_repair": {"const": false}, "capability_evidence": {"const": false}, "professional_validity": {"const": false}, "safety": {"const": false}, "production_fitness": {"const": false}, "readiness_evidence": {"const": false}
        }},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "resourceRegionRef": {"type": "object", "additionalProperties": false, "required": ["resource_id", "region_id"], "properties": {"resource_id": {"$ref": "#/$defs/id"}, "region_id": {"$ref": "#/$defs/id"}}},
    "dependencyTopologyInstrument": {
      "type": "object", "additionalProperties": false,
      "required": ["instrument_id", "version", "matched_controls", "forms", "claim_boundaries", "provenance"],
      "properties": {
        "instrument_id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/text"},
        "matched_controls": {"type": "object", "additionalProperties": false, "required": ["local_operations", "check_count", "horizon", "budget"], "properties": {
          "local_operations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
          "check_count": {"type": "integer", "minimum": 1}, "horizon": {"type": "integer", "minimum": 1}, "budget": {"type": "integer", "minimum": 1}
        }},
        "forms": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["form_id", "topology_treatment", "endpoints", "value_claims", "transformations", "edges", "checks"], "properties": {
          "form_id": {"$ref": "#/$defs/id"}, "topology_treatment": {"enum": ["direct_authorized_transfer", "role_rebound_transfer"]},
          "endpoints": {"type": "array", "minItems": 3, "items": {"type": "object", "additionalProperties": false, "required": ["endpoint_id", "resource_kind", "role", "authority", "valid_interval"], "properties": {
            "endpoint_id": {"$ref": "#/$defs/id"}, "resource_kind": {"enum": ["structured_table", "file_blob", "cache_queue", "external_service"]},
            "role": {"enum": ["authoritative_source", "transformation_workspace", "required_destination", "verification_endpoint"]},
            "authority": {"enum": ["authoritative", "derived", "write_only", "verification_only", "unauthorized"]}, "valid_interval": {"$ref": "#/$defs/text"}
          }}},
          "value_claims": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["claim_id", "semantic_identity", "source_endpoint_id", "source_locator"], "properties": {
            "claim_id": {"$ref": "#/$defs/id"}, "semantic_identity": {"$ref": "#/$defs/sha256"}, "source_endpoint_id": {"$ref": "#/$defs/id"}, "source_locator": {"$ref": "#/$defs/text"}
          }}},
          "transformations": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["transformation_id", "description", "permitted_invariances"], "properties": {
            "transformation_id": {"$ref": "#/$defs/id"}, "description": {"$ref": "#/$defs/text"}, "permitted_invariances": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}
          }}},
          "edges": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["edge_id", "claim_id", "from_endpoint_id", "to_endpoint_id", "transformation_id", "authorized", "depends_on", "downstream_check_ids"], "properties": {
            "edge_id": {"$ref": "#/$defs/id"}, "claim_id": {"$ref": "#/$defs/id"}, "from_endpoint_id": {"$ref": "#/$defs/id"}, "to_endpoint_id": {"$ref": "#/$defs/id"},
            "transformation_id": {"$ref": "#/$defs/id"}, "authorized": {"type": "boolean"}, "depends_on": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
            "downstream_check_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}
          }}},
          "checks": {"type": "array", "minItems": 4, "items": {"type": "object", "additionalProperties": false, "required": ["check_id", "family", "depends_on_edges"], "properties": {
            "check_id": {"$ref": "#/$defs/id"}, "family": {"enum": ["edge_fidelity", "endpoint_state", "global_closure", "collateral_state", "cleanup_reset"]},
            "depends_on_edges": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}
          }}}
        }}},
        "claim_boundaries": {"type": "object", "additionalProperties": false, "required": ["exact_fixture_detection", "coordination_capability", "professional_validity", "safety", "production_fitness", "readiness_evidence"], "properties": {
          "exact_fixture_detection": {"const": true}, "coordination_capability": {"const": false}, "professional_validity": {"const": false}, "safety": {"const": false}, "production_fitness": {"const": false}, "readiness_evidence": {"const": false}
        }},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "dependencyTopologyObservation": {
      "type": "object", "additionalProperties": false,
      "required": ["instrument_id", "version", "cases"],
      "properties": {
        "instrument_id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/text"},
        "cases": {"type": "array", "minItems": 4, "items": {"type": "object", "additionalProperties": false, "required": ["case_id", "form_id", "edge_observations", "check_results", "write_persistence", "collateral", "cleanup", "disposition"], "properties": {
          "case_id": {"$ref": "#/$defs/id"}, "form_id": {"$ref": "#/$defs/id"},
          "edge_observations": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["edge_id", "source_access", "capture", "transformation", "target_write", "persistence", "path_authorized", "evidence"], "properties": {
            "edge_id": {"$ref": "#/$defs/id"}, "source_access": {"enum": ["passed", "failed", "censored", "insufficient_evidence"]}, "capture": {"enum": ["passed", "failed", "censored", "insufficient_evidence"]},
            "transformation": {"enum": ["passed", "failed", "censored", "insufficient_evidence"]}, "target_write": {"enum": ["passed", "failed", "censored", "insufficient_evidence"]},
            "persistence": {"enum": ["passed", "failed", "censored", "insufficient_evidence"]}, "path_authorized": {"type": "boolean"}, "evidence": {"$ref": "#/$defs/text"}
          }}},
          "check_results": {"type": "array", "minItems": 4, "items": {"type": "object", "additionalProperties": false, "required": ["check_id", "family", "outcome", "evidence"], "properties": {
            "check_id": {"$ref": "#/$defs/id"}, "family": {"enum": ["edge_fidelity", "endpoint_state", "global_closure", "collateral_state", "cleanup_reset"]}, "outcome": {"enum": ["passed", "failed", "censored", "insufficient_evidence"]}, "evidence": {"$ref": "#/$defs/text"}
          }}},
          "write_persistence": {"type": "object", "additionalProperties": false, "required": ["attempted", "acknowledged", "reobserved", "authoritative_state"], "properties": {
            "attempted": {"type": "boolean"}, "acknowledged": {"type": "boolean"}, "reobserved": {"type": "boolean"}, "authoritative_state": {"enum": ["present", "absent", "not_observed"]}
          }},
          "collateral": {"enum": ["acceptable", "prohibited_state_observed", "insufficient_evidence"]}, "cleanup": {"enum": ["verified", "residue_observed", "not_run", "insufficient_evidence"]},
          "disposition": {"type": "object", "additionalProperties": false, "required": ["edge_fidelity", "endpoint_closure", "global_closure", "collateral_state", "cleanup_reset"], "properties": {
            "edge_fidelity": {"enum": ["passed", "failed", "censored", "insufficient_evidence"]}, "endpoint_closure": {"enum": ["passed", "failed", "censored", "insufficient_evidence"]},
            "global_closure": {"enum": ["passed", "failed", "censored", "insufficient_evidence"]}, "collateral_state": {"enum": ["passed", "failed", "insufficient_evidence"]}, "cleanup_reset": {"enum": ["passed", "failed", "not_run", "insufficient_evidence"]}
          }}
        }}}
      }
    },
    "observation": {
      "type": "object", "additionalProperties": false,
      "required": ["instrument_id", "version", "session_id", "start_parent_root_sha256", "end_parent_root_sha256", "canary_results", "mutations", "matches", "attempt", "commit_assessment", "overall_disposition"],
      "properties": {
        "instrument_id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/text"}, "session_id": {"$ref": "#/$defs/id"}, "start_parent_root_sha256": {"$ref": "#/$defs/sha256"}, "end_parent_root_sha256": {"$ref": "#/$defs/sha256"},
        "canary_results": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["canary_id", "observed", "evidence"], "properties": {"canary_id": {"$ref": "#/$defs/id"}, "observed": {"enum": ["intercepted", "blocked", "escaped", "not_run"]}, "evidence": {"$ref": "#/$defs/text"}}}},
        "mutations": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["mutation_id", "sequence", "operation_id", "resource_id", "region_id", "item_key", "kind", "before", "after", "depends_on", "context_status", "observation_status"], "properties": {
          "mutation_id": {"$ref": "#/$defs/id"}, "sequence": {"type": "integer", "minimum": 1}, "operation_id": {"$ref": "#/$defs/id"}, "resource_id": {"$ref": "#/$defs/id"}, "region_id": {"$ref": "#/$defs/id"}, "item_key": {"$ref": "#/$defs/text"},
          "kind": {"enum": ["insert", "update", "delete", "increment", "enqueue", "blob_write"]}, "before": {}, "after": {}, "depends_on": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
          "context_status": {"enum": ["tagged", "untagged"]}, "observation_status": {"enum": ["observed", "escaped", "excluded", "unobserved"]}
        }}},
        "matches": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["match_id", "resource_id", "expected_item_key", "candidate_item_keys", "outcome"], "properties": {"match_id": {"$ref": "#/$defs/id"}, "resource_id": {"$ref": "#/$defs/id"}, "expected_item_key": {"$ref": "#/$defs/text"}, "candidate_item_keys": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}, "uniqueItems": true}, "alternative_id": {"$ref": "#/$defs/id"}, "outcome": {"enum": ["accepted", "rejected", "insufficient_evidence"]}}}},
        "attempt": {"type": "object", "additionalProperties": false, "required": ["status", "disposition", "denominator_included"], "properties": {"status": {"enum": ["completed", "failed_evaluation", "invalid_environment"]}, "disposition": {"enum": ["eligible", "failed_attempt", "invalid_attempt"]}, "denominator_included": {"const": true}}},
        "commit_assessment": {"type": "object", "additionalProperties": false, "required": ["requested", "selected_operation_ids", "authorized", "dependency_closure", "stale_base", "decision", "rollback_status"], "properties": {"requested": {"type": "boolean"}, "selected_operation_ids": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "authorized": {"type": "boolean"}, "dependency_closure": {"type": "boolean"}, "stale_base": {"type": "boolean"}, "decision": {"enum": ["discard", "commit", "reject_commit"]}, "rollback_status": {"enum": ["not_needed", "verified", "failed", "not_run"]}}},
        "overall_disposition": {"enum": ["conformant", "insufficient_evidence", "invalid_environment"]}
      }
    }
  }
}
