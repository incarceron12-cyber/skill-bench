{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/expert-participation.schema.json",
  "title": "skill-bench expert participation and authority-lineage package",
  "description": "Purpose-specific consent, reciprocal exchange, transformation lineage, and decision-rights records linked to expertise-transfer contributors. Provenance propagates through transformations; expert approval does not.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "lifecycle_id", "version", "linked_artifacts", "participants", "consent_records", "contribution_units", "derived_artifacts", "transformations", "reviews", "authority_delegations", "decision_rights", "reconsent_events", "release"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "lifecycle_id": {"$ref": "#/$defs/id"},
    "version": {"$ref": "#/$defs/nonEmpty"},
    "linked_artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/linkedArtifact"}},
    "participants": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/participant"}},
    "consent_records": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/consent"}},
    "contribution_units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/contribution"}},
    "derived_artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/derivedArtifact"}},
    "transformations": {"type": "array", "items": {"$ref": "#/$defs/transformation"}},
    "reviews": {"type": "array", "items": {"$ref": "#/$defs/review"}},
    "authority_delegations": {"type": "array", "items": {"$ref": "#/$defs/delegation"}},
    "decision_rights": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/decisionRight"}},
    "reconsent_events": {"type": "array", "items": {"$ref": "#/$defs/reconsent"}},
    "release": {"$ref": "#/$defs/release"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "nonEmpty": {"type": "string", "minLength": 1},
    "relativePath": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "idList": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "purpose": {"enum": ["task_design", "source_pack", "procedural_skill", "training", "evaluation", "release_review", "public_release", "commercial_use", "research"]},
    "linkedArtifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "artifact_type", "path", "sha256", "version"],
      "properties": {"artifact_id": {"$ref": "#/$defs/id"}, "artifact_type": {"enum": ["expertise_transfer_packet", "benchmark_bundle", "participation_evidence", "source_review"]}, "path": {"$ref": "#/$defs/relativePath"}, "sha256": {"$ref": "#/$defs/sha256"}, "version": {"$ref": "#/$defs/nonEmpty"}}
    },
    "participant": {
      "type": "object", "additionalProperties": false,
      "required": ["participant_id", "linked_contributor_id", "actor_type", "role", "expertise_basis", "coverage_boundary", "identity_mode"],
      "properties": {"participant_id": {"$ref": "#/$defs/id"}, "linked_contributor_id": {"$ref": "#/$defs/id"}, "actor_type": {"enum": ["domain_expert", "benchmark_builder", "research_reviewer", "pilot_reviewer"]}, "role": {"$ref": "#/$defs/nonEmpty"}, "expertise_basis": {"$ref": "#/$defs/nonEmpty"}, "coverage_boundary": {"$ref": "#/$defs/nonEmpty"}, "identity_mode": {"enum": ["named", "pseudonymous", "collective", "private"]}}
    },
    "consent": {
      "type": "object", "additionalProperties": false,
      "required": ["consent_id", "participant_id", "version", "effective_at", "allowed_purposes", "prohibited_purposes", "allowed_transformations", "attribution", "license_or_ownership", "compensation", "reciprocal_output", "comprehension_evidence", "withdrawal_boundary", "reconsent_triggers", "status"],
      "properties": {
        "consent_id": {"$ref": "#/$defs/id"}, "participant_id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/nonEmpty"}, "effective_at": {"type": "string", "format": "date-time"},
        "allowed_purposes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/purpose"}, "uniqueItems": true}, "prohibited_purposes": {"type": "array", "items": {"$ref": "#/$defs/purpose"}, "uniqueItems": true},
        "allowed_transformations": {"type": "array", "items": {"enum": ["edit", "summarize", "synthesize", "augment", "operationalize", "apply"]}, "uniqueItems": true},
        "attribution": {"enum": ["named", "pseudonymous", "collective", "private", "not_applicable"]}, "license_or_ownership": {"$ref": "#/$defs/nonEmpty"},
        "compensation": {"type": "object", "additionalProperties": false, "required": ["basis", "amount_or_none", "currency_or_none"], "properties": {"basis": {"enum": ["hourly", "fixed", "in_kind", "none", "not_applicable"]}, "amount_or_none": {"$ref": "#/$defs/nonEmpty"}, "currency_or_none": {"$ref": "#/$defs/nonEmpty"}}},
        "reciprocal_output": {"type": "object", "additionalProperties": false, "required": ["description", "delivery_status"], "properties": {"description": {"$ref": "#/$defs/nonEmpty"}, "delivery_status": {"enum": ["promised", "delivered", "declined", "not_applicable"]}}},
        "comprehension_evidence": {"type": "object", "additionalProperties": false, "required": ["method", "concrete_example_locator", "participant_disposition", "captured_at"], "properties": {"method": {"enum": ["input_transformation_output_walkthrough", "teach_back", "worked_example_review", "not_applicable_internal_fixture"]}, "concrete_example_locator": {"$ref": "#/$defs/nonEmpty"}, "participant_disposition": {"enum": ["demonstrated", "correction_requested", "not_demonstrated", "not_applicable"]}, "captured_at": {"type": "string", "format": "date-time"}}},
        "withdrawal_boundary": {"$ref": "#/$defs/nonEmpty"}, "reconsent_triggers": {"type": "array", "minItems": 1, "items": {"enum": ["new_purpose", "commercial_use", "public_release", "synthetic_derivation", "material_role_change", "license_change"]}, "uniqueItems": true}, "status": {"enum": ["active", "withdrawn", "superseded", "not_applicable_internal_fixture"]}
      }
    },
    "contribution": {
      "type": "object", "additionalProperties": false,
      "required": ["contribution_id", "participant_id", "consent_id", "unit_type", "purpose", "artifact_ids", "contributor_minutes", "review_state"],
      "properties": {"contribution_id": {"$ref": "#/$defs/id"}, "participant_id": {"$ref": "#/$defs/id"}, "consent_id": {"$ref": "#/$defs/id"}, "unit_type": {"enum": ["critical_incident", "requirement", "example", "rubric_edit", "rating", "adjudication", "contract_calibration"]}, "purpose": {"$ref": "#/$defs/purpose"}, "artifact_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "contributor_minutes": {"type": "integer", "minimum": 0}, "review_state": {"enum": ["submitted", "accepted", "disputed", "withdrawn", "internal_calibration_only"]}}
    },
    "derivedArtifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "artifact_kind", "path", "sha256", "creator_actor_type", "authority_state", "source_contribution_ids", "current_purposes"],
      "properties": {"artifact_id": {"$ref": "#/$defs/id"}, "artifact_kind": {"enum": ["testimony", "requirement", "rubric", "example", "synthetic_variant", "grader", "review_record", "contract_fixture"]}, "path": {"$ref": "#/$defs/relativePath"}, "sha256": {"$ref": "#/$defs/sha256"}, "creator_actor_type": {"enum": ["domain_expert", "benchmark_builder", "model", "script", "research_reviewer"]}, "authority_state": {"enum": ["expert_authored", "expert_edited", "expert_approved", "builder_authored", "expert_derived_unreviewed", "model_derived_unreviewed", "script_derived_unreviewed", "internal_calibration_only"]}, "source_contribution_ids": {"$ref": "#/$defs/idList"}, "current_purposes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/purpose"}, "uniqueItems": true}}
    },
    "transformation": {
      "type": "object", "additionalProperties": false,
      "required": ["transformation_id", "input_artifact_ids", "output_artifact_id", "actor_type", "operation", "purpose", "material", "consent_ids", "review_ids"],
      "properties": {"transformation_id": {"$ref": "#/$defs/id"}, "input_artifact_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "output_artifact_id": {"$ref": "#/$defs/id"}, "actor_type": {"enum": ["domain_expert", "benchmark_builder", "model", "script"]}, "operation": {"enum": ["edit", "summarize", "synthesize", "augment", "operationalize", "apply"]}, "purpose": {"$ref": "#/$defs/purpose"}, "material": {"type": "boolean"}, "consent_ids": {"$ref": "#/$defs/idList"}, "review_ids": {"$ref": "#/$defs/idList"}}
    },
    "review": {
      "type": "object", "additionalProperties": false,
      "required": ["review_id", "review_type", "artifact_id", "transformation_id", "reviewer_participant_id", "evidence_artifact_id", "disposition", "held_out", "reviewed_at", "scope"],
      "properties": {"review_id": {"$ref": "#/$defs/id"}, "review_type": {"enum": ["transformation_fidelity", "held_out_application_fidelity", "release_claim", "consent_comprehension", "internal_contract_review"]}, "artifact_id": {"$ref": "#/$defs/id"}, "transformation_id": {"type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9._-]*$"}, "reviewer_participant_id": {"$ref": "#/$defs/id"}, "evidence_artifact_id": {"$ref": "#/$defs/id"}, "disposition": {"enum": ["approved", "rejected", "disputed", "not_applicable_internal_fixture"]}, "held_out": {"type": "boolean"}, "reviewed_at": {"type": "string", "format": "date-time"}, "scope": {"$ref": "#/$defs/nonEmpty"}}
    },
    "delegation": {
      "type": "object", "additionalProperties": false,
      "required": ["delegation_id", "standard_artifact_id", "from_actor_type", "to_actor_type", "application_purpose", "fidelity_review_id", "status"],
      "properties": {"delegation_id": {"$ref": "#/$defs/id"}, "standard_artifact_id": {"$ref": "#/$defs/id"}, "from_actor_type": {"const": "domain_expert"}, "to_actor_type": {"enum": ["benchmark_builder", "model", "script"]}, "application_purpose": {"$ref": "#/$defs/purpose"}, "fidelity_review_id": {"type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9._-]*$"}, "status": {"enum": ["proposed", "approved", "blocked", "not_applicable_internal_fixture"]}}
    },
    "decisionRight": {
      "type": "object", "additionalProperties": false,
      "required": ["right_id", "participant_id", "scope", "actions"],
      "properties": {"right_id": {"$ref": "#/$defs/id"}, "participant_id": {"$ref": "#/$defs/id"}, "scope": {"$ref": "#/$defs/nonEmpty"}, "actions": {"type": "array", "minItems": 1, "items": {"enum": ["author", "review", "veto_misrepresentation", "approve_transformation", "approve_release_claim", "withdraw"]}, "uniqueItems": true}}
    },
    "reconsent": {
      "type": "object", "additionalProperties": false,
      "required": ["event_id", "trigger", "old_consent_id", "new_consent_id", "affected_artifact_ids", "occurred_at"],
      "properties": {"event_id": {"$ref": "#/$defs/id"}, "trigger": {"enum": ["new_purpose", "commercial_use", "public_release", "synthetic_derivation", "material_role_change", "license_change"]}, "old_consent_id": {"$ref": "#/$defs/id"}, "new_consent_id": {"$ref": "#/$defs/id"}, "affected_artifact_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "occurred_at": {"type": "string", "format": "date-time"}}
    },
    "release": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "expert_grounding_claim", "approved_artifact_ids", "claim_review_ids", "known_limitations"],
      "properties": {"status": {"enum": ["not_ready", "pilot_only", "releasable"]}, "expert_grounding_claim": {"enum": ["none", "bounded", "validated"]}, "approved_artifact_ids": {"$ref": "#/$defs/idList"}, "claim_review_ids": {"$ref": "#/$defs/idList"}, "known_limitations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}}}
    }
  }
}
