{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/objective-calibration.schema.json",
  "title": "skill-bench native objective calibration package",
  "description": "Linked extension preserving native objective loss, reference strength, normalization, hard feasibility, portfolio thresholds, and staged aggregation sensitivity.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_id", "version", "artifacts", "evidence", "objective_calibrations"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "package_id": {"$ref": "#/$defs/id"},
    "version": {"$ref": "#/$defs/text"},
    "artifacts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifact"}},
    "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
    "objective_calibrations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/objectiveCalibration"}}
  },
  "$defs": {
    "text": {"type": "string", "minLength": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "ids": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "artifact_type", "path", "version", "sha256"],
      "properties": {"artifact_id": {"$ref": "#/$defs/id"}, "artifact_type": {"enum": ["measurement", "reference", "validity_argument", "metric_specification"]}, "path": {"$ref": "#/$defs/path"}, "version": {"$ref": "#/$defs/text"}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["evidence_id", "artifact_ref_ids", "locator", "description", "limitations"],
      "properties": {"evidence_id": {"$ref": "#/$defs/id"}, "artifact_ref_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}, "locator": {"$ref": "#/$defs/text"}, "description": {"$ref": "#/$defs/text"}, "limitations": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}}}
    },
    "objectiveObservation": {
      "type": "object", "additionalProperties": false,
      "required": ["observation_id", "artifact_shape", "stage_id", "direction", "native_unit", "native_value", "hard_feasibility", "reference", "calibration_mode", "native_regret", "native_loss", "normalized"],
      "properties": {
        "observation_id": {"$ref": "#/$defs/id"}, "artifact_shape": {"$ref": "#/$defs/text"}, "stage_id": {"type": ["string", "null"], "minLength": 1}, "direction": {"enum": ["minimize", "maximize"]},
        "native_unit": {"$ref": "#/$defs/text"}, "native_value": {"type": "number"}, "hard_feasibility": {"enum": ["passed", "failed", "not_evaluated"]},
        "reference": {"type": "object", "additionalProperties": false, "required": ["reference_id", "method", "strength", "value", "bound", "poor_anchor"], "properties": {
          "reference_id": {"$ref": "#/$defs/id"}, "method": {"enum": ["exact_solver", "solver_bound", "relative_gap_reference", "heuristic", "poor_anchor", "none"]}, "strength": {"enum": ["proven_optimum", "valid_bound", "reference_only", "heuristic", "unknown", "not_applicable"]}, "value": {"type": ["number", "null"]}, "bound": {"type": ["number", "null"]}, "poor_anchor": {"type": ["number", "null"]}
        }},
        "calibration_mode": {"enum": ["bound_based", "relative_gap_fallback", "poor_anchor", "unnormalized"]}, "native_regret": {"type": ["number", "null"], "minimum": 0}, "native_loss": {"type": ["number", "null"], "minimum": 0},
        "normalized": {"type": "object", "additionalProperties": false, "required": ["value", "mapping", "clipped", "clip_interval"], "properties": {"value": {"type": ["number", "null"]}, "mapping": {"$ref": "#/$defs/text"}, "clipped": {"type": "boolean"}, "clip_interval": {"type": ["array", "null"], "prefixItems": [{"type": "number"}, {"type": "number"}], "items": false, "minItems": 2, "maxItems": 2}}}
      }
    },
    "objectiveCalibration": {
      "type": "object", "additionalProperties": false,
      "required": ["calibration_id", "measurement_ref_id", "observations", "threshold", "portfolio_policy", "disposition", "claim_boundary"],
      "properties": {
        "calibration_id": {"$ref": "#/$defs/id"}, "measurement_ref_id": {"$ref": "#/$defs/id"}, "observations": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/objectiveObservation"}},
        "threshold": {"type": "object", "additionalProperties": false, "required": ["scope", "basis", "direction", "value", "meaning"], "properties": {"scope": {"enum": ["per_observation", "common_portfolio"]}, "basis": {"enum": ["native_loss", "normalized_value", "declared_portfolio_loss"]}, "direction": {"enum": ["at_most", "at_least"]}, "value": {"type": "number"}, "meaning": {"$ref": "#/$defs/text"}}},
        "portfolio_policy": {"type": "object", "additionalProperties": false, "required": ["estimand", "loss_basis", "hard_feasibility_policy", "calibration_mode_pooling", "bridge_evidence_ids", "stage_aggregation", "sensitivity_outputs"], "properties": {
          "estimand": {"$ref": "#/$defs/text"}, "loss_basis": {"$ref": "#/$defs/text"}, "hard_feasibility_policy": {"enum": ["noncompensatory", "compensatory"]}, "calibration_mode_pooling": {"enum": ["stratified", "bridged", "pooled"]}, "bridge_evidence_ids": {"$ref": "#/$defs/ids"}, "stage_aggregation": {"enum": ["not_applicable", "mean", "cumulative", "terminal", "worst_stage", "declared_utility"]},
          "sensitivity_outputs": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["policy", "value", "disposition"], "properties": {"policy": {"enum": ["mean", "cumulative", "terminal", "worst_stage", "declared_utility"]}, "value": {"type": "number"}, "disposition": {"enum": ["accepted", "rejected", "invalid"]}}}}
        }},
        "disposition": {"enum": ["accepted", "rejected", "invalid"]}, "claim_boundary": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/text"}}
      }
    }
  }
}
