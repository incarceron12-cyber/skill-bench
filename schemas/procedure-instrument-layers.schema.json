{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/procedure-instrument-layers.schema.json",
  "title": "Layered procedure instrument conformance record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_id", "instrument_shape", "migration_freeze", "source_bindings", "claim_limits", "package_layer", "environment_layer", "trial_layer", "reported_layers", "claims"],
  "properties": {
    "schema_version": {"const": "0.2.0"},
    "record_id": {"$ref": "#/$defs/id"},
    "instrument_shape": {"enum": ["tabular_mock_tool", "stateful_terminal_state"]},
    "migration_freeze": {"$ref": "#/$defs/binding"},
    "source_bindings": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/binding"}},
    "claim_limits": {
      "type": "object", "additionalProperties": false,
      "required": ["internal_calibration_only", "unsupported"],
      "properties": {
        "internal_calibration_only": {"type": "boolean"},
        "unsupported": {"type": "array", "minItems": 6, "uniqueItems": true, "items": {"$ref": "#/$defs/text"}}
      }
    },
    "package_layer": {
      "type": "object", "additionalProperties": false,
      "required": ["inventory", "versions", "roles", "access_boundary", "answer_bearing_tools", "prohibited_oracles"],
      "properties": {
        "inventory": {"$ref": "#/$defs/evidence"},
        "versions": {"$ref": "#/$defs/evidence"},
        "roles": {"type": "array", "minItems": 6, "items": {"$ref": "#/$defs/role"}},
        "access_boundary": {
          "type": "object", "additionalProperties": false, "required": ["evidence", "enforced"],
          "properties": {"evidence": {"$ref": "#/$defs/evidence"}, "enforced": {"type": "boolean"}}
        },
        "answer_bearing_tools": {
          "type": "object", "additionalProperties": false, "required": ["evidence", "detected"],
          "properties": {"evidence": {"$ref": "#/$defs/evidence"}, "detected": {"type": "boolean"}}
        },
        "prohibited_oracles": {"type": "array", "items": {"$ref": "#/$defs/oracle_access"}}
      }
    },
    "environment_layer": {
      "type": "object", "additionalProperties": false,
      "required": ["adapter_identity", "runtime_identity", "shape_contract", "deterministic_replay", "replay_deterministic"],
      "properties": {
        "adapter_identity": {"$ref": "#/$defs/evidence"},
        "runtime_identity": {"$ref": "#/$defs/evidence"},
        "shape_contract": {"$ref": "#/$defs/evidence"},
        "deterministic_replay": {"$ref": "#/$defs/evidence"},
        "replay_deterministic": {"type": ["boolean", "null"]}
      }
    },
    "trial_layer": {
      "type": "object", "additionalProperties": false,
      "required": ["procedure_observation", "final_state_observation", "endpoint_observation", "alternative_inventory", "endpoint_source", "declared_alternative_ids", "accepted_alternative_ids", "procedure_result", "endpoint_result"],
      "properties": {
        "procedure_observation": {"$ref": "#/$defs/evidence"},
        "final_state_observation": {"$ref": "#/$defs/evidence"},
        "endpoint_observation": {"$ref": "#/$defs/evidence"},
        "alternative_inventory": {"$ref": "#/$defs/evidence"},
        "endpoint_source": {"enum": ["final_artifact", "terminal_state", "reasoning_trace", "unavailable"]},
        "declared_alternative_ids": {"$ref": "#/$defs/id_array"},
        "accepted_alternative_ids": {"$ref": "#/$defs/id_array"},
        "procedure_result": {"enum": ["pass", "fail", "unavailable"]},
        "endpoint_result": {"enum": ["pass", "fail", "unavailable"]}
      }
    },
    "reported_layers": {
      "type": "object", "additionalProperties": false,
      "required": ["package", "environment", "trial"],
      "properties": {
        "package": {"$ref": "#/$defs/outcome"}, "environment": {"$ref": "#/$defs/outcome"}, "trial": {"$ref": "#/$defs/outcome"}
      }
    },
    "claims": {
      "type": "array", "minItems": 3, "items": {
        "type": "object", "additionalProperties": false, "required": ["layer", "status", "statement"],
        "properties": {"layer": {"enum": ["package", "environment", "trial"]}, "status": {"enum": ["supported", "unsupported"]}, "statement": {"$ref": "#/$defs/text"}}
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
    "text": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "id_array": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "binding": {
      "type": "object", "additionalProperties": false, "required": ["binding_id", "path", "sha256", "purpose"],
      "properties": {"binding_id": {"$ref": "#/$defs/id"}, "path": {"$ref": "#/$defs/text"}, "sha256": {"$ref": "#/$defs/sha256"}, "purpose": {"$ref": "#/$defs/text"}}
    },
    "evidence": {
      "type": "object", "additionalProperties": false, "required": ["evidence_id", "status", "reason", "provenance_refs"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/id"},
        "status": {"enum": ["complete", "partial", "unavailable", "prohibited"]},
        "reason": {"$ref": "#/$defs/text"},
        "provenance_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}}
      }
    },
    "role": {
      "type": "object", "additionalProperties": false, "required": ["role", "surface", "evidence"],
      "properties": {
        "role": {"enum": ["public_input", "hidden_evidence", "tool_result", "scored_endpoint", "audit_metadata", "prohibited_oracle"]},
        "surface": {"enum": ["public_task", "scored_runtime", "private_evaluator", "audit_only", "unavailable"]},
        "evidence": {"$ref": "#/$defs/evidence"}
      }
    },
    "oracle_access": {
      "type": "object", "additionalProperties": false, "required": ["oracle_id", "binding_ref", "scored_run_access"],
      "properties": {"oracle_id": {"$ref": "#/$defs/id"}, "binding_ref": {"$ref": "#/$defs/id"}, "scored_run_access": {"enum": ["prohibited", "exposed", "unverified"]}}
    },
    "outcome": {"enum": ["pass", "fail", "insufficient_evidence", "prohibited"]}
  }
}
