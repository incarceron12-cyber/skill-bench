{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/procedure-package.schema.json",
  "title": "Cross-domain procedure package conformance manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_id", "version", "provenance", "claim_limits", "frozen_execution", "fields", "table_contract", "integrity_texts", "tools", "oracle", "comparators", "procedure", "trials"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "package_id": {"$ref": "#/$defs/id"},
    "version": {"$ref": "#/$defs/text"},
    "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}},
    "claim_limits": {"$ref": "#/$defs/claim_limits"},
    "frozen_execution": {"$ref": "#/$defs/frozen_execution"},
    "fields": {"type": "array", "minItems": 5, "items": {"$ref": "#/$defs/field"}},
    "table_contract": {"$ref": "#/$defs/table_contract"},
    "integrity_texts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/integrity_text"}},
    "tools": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/tool"}},
    "oracle": {"$ref": "#/$defs/oracle"},
    "comparators": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/comparator"}},
    "procedure": {"$ref": "#/$defs/procedure"},
    "trials": {"type": "array", "minItems": 5, "items": {"$ref": "#/$defs/trial"}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9._-]*$"},
    "text": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "id_array": {"type": "array", "items": {"$ref": "#/$defs/id"}, "uniqueItems": true},
    "component": {
      "type": "object", "additionalProperties": false,
      "required": ["component_id", "version", "sha256"],
      "properties": {"component_id": {"$ref": "#/$defs/id"}, "version": {"$ref": "#/$defs/text"}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["source_id", "locator", "local_path", "claim"],
      "properties": {"source_id": {"$ref": "#/$defs/id"}, "locator": {"$ref": "#/$defs/text"}, "local_path": {"$ref": "#/$defs/text"}, "claim": {"$ref": "#/$defs/text"}}
    },
    "claim_limits": {
      "type": "object", "additionalProperties": false,
      "required": ["internal_calibration_only", "supported", "unsupported"],
      "properties": {
        "internal_calibration_only": {"const": true},
        "supported": {"type": "array", "items": {"$ref": "#/$defs/text"}, "uniqueItems": true},
        "unsupported": {"type": "array", "minItems": 6, "items": {"$ref": "#/$defs/text"}, "uniqueItems": true}
      }
    },
    "frozen_execution": {
      "type": "object", "additionalProperties": false,
      "required": ["generator", "loader", "tool_runtime", "oracle_implementation", "seed", "frozen_time"],
      "properties": {
        "generator": {"$ref": "#/$defs/component"}, "loader": {"$ref": "#/$defs/component"},
        "tool_runtime": {"$ref": "#/$defs/component"}, "oracle_implementation": {"$ref": "#/$defs/component"},
        "seed": {"type": "integer", "minimum": 0}, "frozen_time": {"type": "string", "format": "date-time"}
      }
    },
    "field": {
      "type": "object", "additionalProperties": false,
      "required": ["field_id", "role", "type", "surface"],
      "properties": {
        "field_id": {"$ref": "#/$defs/id"},
        "role": {"enum": ["public_input", "hidden_evidence", "tool_result", "scored_endpoint", "audit_metadata", "prohibited_oracle"]},
        "type": {"enum": ["string", "enum", "boolean", "number", "date", "set", "object"]},
        "surface": {"enum": ["public_task", "hidden_table", "tool_only", "final_artifact", "audit_only", "private_oracle"]}
      }
    },
    "table_contract": {
      "type": "object", "additionalProperties": false,
      "required": ["metadata_columns", "observed_columns", "manifest_row_count", "loaded_row_count"],
      "properties": {
        "metadata_columns": {"$ref": "#/$defs/id_array"}, "observed_columns": {"$ref": "#/$defs/id_array"},
        "manifest_row_count": {"type": "integer", "minimum": 1}, "loaded_row_count": {"type": "integer", "minimum": 0}
      }
    },
    "integrity_text": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "content"],
      "properties": {"path": {"$ref": "#/$defs/text"}, "content": {"type": "string"}}
    },
    "argument": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "type", "required", "used_by_implementation"],
      "properties": {"name": {"$ref": "#/$defs/id"}, "type": {"enum": ["string", "boolean", "number", "date", "object"]}, "required": {"type": "boolean"}, "used_by_implementation": {"type": "boolean"}}
    },
    "tool": {
      "type": "object", "additionalProperties": false,
      "required": ["tool_id", "component", "arguments", "return_field_ids", "answer_bearing", "deterministic", "replay_digests"],
      "properties": {
        "tool_id": {"$ref": "#/$defs/id"}, "component": {"$ref": "#/$defs/component"},
        "arguments": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/argument"}},
        "return_field_ids": {"$ref": "#/$defs/id_array"}, "answer_bearing": {"type": "boolean"},
        "deterministic": {"type": "boolean"}, "replay_digests": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/sha256"}}
      }
    },
    "oracle": {
      "type": "object", "additionalProperties": false,
      "required": ["endpoint_field_ids", "input_field_ids", "independent_derivation", "derivation_component", "reference_case_ids"],
      "properties": {
        "endpoint_field_ids": {"$ref": "#/$defs/id_array"}, "input_field_ids": {"$ref": "#/$defs/id_array"},
        "independent_derivation": {"type": "boolean"}, "derivation_component": {"$ref": "#/$defs/component"},
        "reference_case_ids": {"$ref": "#/$defs/id_array"}
      }
    },
    "comparator": {
      "type": "object", "additionalProperties": false,
      "required": ["field_id", "kind", "null_policy"],
      "properties": {
        "field_id": {"$ref": "#/$defs/id"},
        "kind": {"enum": ["exact_enum", "exact_string", "boolean", "number_tolerance", "date", "set_equality", "json_schema", "substring"]},
        "null_policy": {"enum": ["distinct", "explicit_missing_only", "collapse_null_like"]},
        "tolerance": {"type": "number", "minimum": 0}
      }
    },
    "clause": {
      "type": "object", "additionalProperties": false,
      "required": ["clause_id", "kind", "public_basis", "evidence_source_ids"],
      "properties": {
        "clause_id": {"$ref": "#/$defs/id"}, "kind": {"enum": ["step", "gate", "fallback", "artifact"]},
        "public_basis": {"type": "boolean"}, "evidence_source_ids": {"$ref": "#/$defs/id_array"}
      }
    },
    "relation": {
      "type": "object", "additionalProperties": false,
      "required": ["relation_id", "kind", "from_clause_id", "to_clause_id"],
      "properties": {
        "relation_id": {"$ref": "#/$defs/id"}, "kind": {"enum": ["ordering", "gate", "fallback"]},
        "from_clause_id": {"$ref": "#/$defs/id"}, "to_clause_id": {"$ref": "#/$defs/id"},
        "trigger_field_id": {"$ref": "#/$defs/id"}, "trigger_value": {}
      }
    },
    "path": {
      "type": "object", "additionalProperties": false,
      "required": ["path_id", "required_clause_ids", "required_relation_ids"],
      "properties": {"path_id": {"$ref": "#/$defs/id"}, "required_clause_ids": {"$ref": "#/$defs/id_array"}, "required_relation_ids": {"$ref": "#/$defs/id_array"}}
    },
    "procedure": {
      "type": "object", "additionalProperties": false,
      "required": ["clauses", "relations", "accepted_paths"],
      "properties": {
        "clauses": {"type": "array", "minItems": 4, "items": {"$ref": "#/$defs/clause"}},
        "relations": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/relation"}},
        "accepted_paths": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/path"}}
      }
    },
    "event": {
      "type": "object", "additionalProperties": false,
      "required": ["event_id", "sequence", "kind", "clause_id"],
      "properties": {
        "event_id": {"$ref": "#/$defs/id"}, "sequence": {"type": "integer", "minimum": 1},
        "kind": {"enum": ["observation", "tool_call", "decision", "artifact_write"]}, "clause_id": {"$ref": "#/$defs/id"},
        "tool_id": {"$ref": "#/$defs/id"}, "arguments": {"type": "object"}, "runtime_status": {"enum": ["success", "error"]}
      }
    },
    "trial": {
      "type": "object", "additionalProperties": false,
      "required": ["trial_id", "case_values", "events", "final_artifact", "reported"],
      "properties": {
        "trial_id": {"$ref": "#/$defs/id"}, "case_values": {"type": "object"},
        "events": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/event"}},
        "final_artifact": {
          "type": "object", "additionalProperties": false,
          "required": ["endpoint_source", "values"],
          "properties": {"endpoint_source": {"enum": ["final_artifact", "reasoning_trace"]}, "values": {"type": "object"}}
        },
        "reported": {
          "type": "object", "additionalProperties": false,
          "required": ["runtime_metric_label", "runtime_success", "endpoint_match", "procedure_status", "accepted_path_ids", "joint_status"],
          "properties": {
            "runtime_metric_label": {"enum": ["runtime_execution", "tool_accuracy"]}, "runtime_success": {"type": "boolean"},
            "endpoint_match": {"type": "boolean"}, "procedure_status": {"enum": ["conformant", "procedure_wrong", "insufficient_evidence"]},
            "accepted_path_ids": {"$ref": "#/$defs/id_array"}, "joint_status": {"enum": ["passed", "failed", "invalid"]}
          }
        }
      }
    }
  }
}
