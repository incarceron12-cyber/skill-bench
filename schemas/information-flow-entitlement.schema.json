{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/information-flow-entitlement.schema.json",
  "title": "skill-bench information-flow entitlement conformance package",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_id", "status", "design", "actors", "information_atoms", "entitlements", "transformations", "observations", "claim_limits"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "package_id": {"$ref": "#/$defs/id"},
    "status": {"const": "internal_synthetic_contract_calibration"},
    "design": {"type": "object", "additionalProperties": false, "required": ["source_review", "source_pdf", "reused_contracts", "rationale"], "properties": {"source_review": {"$ref": "#/$defs/path"}, "source_pdf": {"$ref": "#/$defs/path"}, "reused_contracts": {"type": "array", "items": {"$ref": "#/$defs/path"}, "uniqueItems": true}, "rationale": {"$ref": "#/$defs/text"}}},
    "actors": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["actor_id", "role"], "properties": {"actor_id": {"$ref": "#/$defs/id"}, "role": {"$ref": "#/$defs/text"}}}},
    "information_atoms": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["atom_id", "subject", "source", "raw_fingerprint", "sensitivity"], "properties": {"atom_id": {"$ref": "#/$defs/id"}, "subject": {"$ref": "#/$defs/text"}, "source": {"$ref": "#/$defs/text"}, "raw_fingerprint": {"$ref": "#/$defs/text"}, "sensitivity": {"enum": ["public", "controlled", "private"]}}}},
    "entitlements": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["entitlement_id", "atom_id", "actor_id", "purpose", "valid_from", "valid_until", "access", "use", "disclosure", "retention", "allowed_representations", "allowed_surfaces"], "properties": {"entitlement_id": {"$ref": "#/$defs/id"}, "atom_id": {"$ref": "#/$defs/id"}, "actor_id": {"$ref": "#/$defs/id"}, "purpose": {"$ref": "#/$defs/id"}, "valid_from": {"$ref": "#/$defs/dateTime"}, "valid_until": {"$ref": "#/$defs/dateTime"}, "access": {"enum": ["permitted", "prohibited"]}, "use": {"enum": ["raw_permitted", "derived_only", "prohibited"]}, "disclosure": {"enum": ["raw_permitted", "derived_only", "prohibited"]}, "retention": {"enum": ["ephemeral", "private_store", "shared_store", "prohibited"]}, "allowed_representations": {"type": "array", "items": {"enum": ["raw", "sanitized_constraint", "aggregate", "redacted"]}, "uniqueItems": true}, "allowed_surfaces": {"type": "array", "items": {"enum": ["private_context", "agent_message", "tool_argument", "shared_memory", "private_memory", "artifact", "final_response"]}, "uniqueItems": true}}}},
    "transformations": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["transformation_id", "input_atom_id", "output_representation", "rule", "preserves_operational_consequence", "suppresses_raw_fingerprint", "authorized_recipients"], "properties": {"transformation_id": {"$ref": "#/$defs/id"}, "input_atom_id": {"$ref": "#/$defs/id"}, "output_representation": {"enum": ["sanitized_constraint", "aggregate", "redacted"]}, "rule": {"$ref": "#/$defs/text"}, "preserves_operational_consequence": {"type": "boolean"}, "suppresses_raw_fingerprint": {"type": "boolean"}, "authorized_recipients": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/id"}, "uniqueItems": true}}}},
    "observations": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["observation_id", "atom_id", "actor_id", "purpose", "timestamp", "surface", "operation", "representation", "transformation_id", "content", "outcome"], "properties": {"observation_id": {"$ref": "#/$defs/id"}, "atom_id": {"$ref": "#/$defs/id"}, "actor_id": {"$ref": "#/$defs/id"}, "purpose": {"$ref": "#/$defs/id"}, "timestamp": {"$ref": "#/$defs/dateTime"}, "surface": {"enum": ["private_context", "agent_message", "tool_argument", "shared_memory", "private_memory", "artifact", "final_response"]}, "operation": {"enum": ["access", "use", "disclosure", "retention"]}, "representation": {"enum": ["raw", "sanitized_constraint", "aggregate", "redacted"]}, "transformation_id": {"oneOf": [{"$ref": "#/$defs/id"}, {"type": "null"}]}, "content": {"$ref": "#/$defs/text"}, "outcome": {"enum": ["permitted", "transformed", "prohibited"]}}}},
    "claim_limits": {"type": "object", "additionalProperties": false, "required": ["supported", "unsupported"], "properties": {"supported": {"type": "array", "items": {"$ref": "#/$defs/text"}}, "unsupported": {"type": "array", "items": {"$ref": "#/$defs/text"}, "uniqueItems": true}}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "text": {"type": "string", "minLength": 1},
    "path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "dateTime": {"type": "string", "format": "date-time"}
  }
}
