{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skill-bench.local/schemas/expertise-transfer.schema.json",
  "title": "skill-bench expertise-to-evaluation authoring packet",
  "description": "A provenance-preserving contract from elicited or observed expertise through benchmark primitives, scenarios, source packs, traps, artifact contracts, checks, validation, and release review.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pipeline_id", "version", "current_stage", "contributors", "claims", "primitives", "scenarios", "sources", "traps", "artifact_contracts", "checks", "quality_gates", "release"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "pipeline_id": {"$ref": "#/$defs/identifier"},
    "version": {"$ref": "#/$defs/nonEmpty"},
    "current_stage": {"$ref": "#/$defs/stage"},
    "contributors": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/contributor"}},
    "claims": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/claim"}},
    "primitives": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/primitive"}},
    "scenarios": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/scenario"}},
    "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}},
    "traps": {"type": "array", "items": {"$ref": "#/$defs/trap"}},
    "artifact_contracts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/artifactContract"}},
    "checks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/check"}},
    "quality_gates": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"$ref": "#/$defs/gate"}},
    "release": {"$ref": "#/$defs/release"}
  },
  "$defs": {
    "nonEmpty": {"type": "string", "minLength": 1},
    "identifier": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "relativePath": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"},
    "idList": {"type": "array", "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
    "visibility": {"enum": ["public", "private", "hidden", "internal_calibration"]},
    "stage": {"enum": ["elicitation", "primitive_mapping", "scenario_design", "source_pack", "rubric", "pilot_validation", "release_review"]},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locator", "description"],
      "properties": {
        "locator": {"$ref": "#/$defs/nonEmpty"},
        "local_path": {"$ref": "#/$defs/relativePath"},
        "section_or_pages": {"type": "string"},
        "description": {"$ref": "#/$defs/nonEmpty"}
      }
    },
    "contributor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contributor_id", "role", "expertise_basis", "contribution_mode"],
      "properties": {
        "contributor_id": {"$ref": "#/$defs/identifier"},
        "role": {"$ref": "#/$defs/nonEmpty"},
        "expertise_basis": {"$ref": "#/$defs/nonEmpty"},
        "contribution_mode": {"enum": ["domain_expert", "benchmark_research_review", "benchmark_builder", "pilot_reviewer"]},
        "consent_scope": {"enum": ["internal_only", "attributed_release", "anonymous_release", "not_applicable"]}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "contributor_id", "evidence_basis", "statement", "locator", "confidence", "corroboration_status", "provenance"],
      "properties": {
        "claim_id": {"$ref": "#/$defs/identifier"},
        "contributor_id": {"$ref": "#/$defs/identifier"},
        "evidence_basis": {"enum": ["expert_statement", "critical_incident", "work_observation", "artifact_example", "primary_source", "benchmark_review", "synthetic_hypothesis"]},
        "statement": {"$ref": "#/$defs/nonEmpty"},
        "locator": {"$ref": "#/$defs/nonEmpty"},
        "confidence": {"enum": ["low", "medium", "high"]},
        "corroboration_status": {"enum": ["unreviewed", "single_source", "corroborated", "disputed"]},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "primitive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primitive_id", "kind", "statement", "claim_ids", "visibility", "uncertainty", "scenario_ids", "check_ids"],
      "properties": {
        "primitive_id": {"$ref": "#/$defs/identifier"},
        "kind": {"enum": ["hidden_requirement", "trusted_evidence_rule", "contradiction", "expert_caveat", "decision_threshold", "artifact_convention", "stakeholder_preference", "polished_but_wrong_trap", "failure_signature", "safety_compliance_constraint"]},
        "statement": {"$ref": "#/$defs/nonEmpty"},
        "claim_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "visibility": {"$ref": "#/$defs/visibility"},
        "uncertainty": {"enum": ["low", "medium", "high", "disputed"]},
        "scenario_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "check_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true}
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_id", "role", "stakeholder", "decision", "critical_incident", "primitive_ids", "source_ids", "trap_ids", "artifact_ids"],
      "properties": {
        "scenario_id": {"$ref": "#/$defs/identifier"},
        "role": {"$ref": "#/$defs/nonEmpty"},
        "stakeholder": {"$ref": "#/$defs/nonEmpty"},
        "decision": {"$ref": "#/$defs/nonEmpty"},
        "critical_incident": {"$ref": "#/$defs/nonEmpty"},
        "primitive_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "source_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "trap_ids": {"$ref": "#/$defs/idList"},
        "artifact_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "path", "media_type", "visibility", "trust_rank", "provenance"],
      "properties": {
        "source_id": {"$ref": "#/$defs/identifier"},
        "path": {"$ref": "#/$defs/relativePath"},
        "media_type": {"$ref": "#/$defs/nonEmpty"},
        "visibility": {"$ref": "#/$defs/visibility"},
        "trust_rank": {"type": "integer", "minimum": 1},
        "provenance": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/provenance"}}
      }
    },
    "trap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trap_id", "kind", "mechanism", "primitive_ids", "source_ids", "failure_signature", "fairness_basis"],
      "properties": {
        "trap_id": {"$ref": "#/$defs/identifier"},
        "kind": {"enum": ["contradiction", "stale_source", "plausible_distractor", "missing_data", "polished_but_wrong", "safety_boundary"]},
        "mechanism": {"$ref": "#/$defs/nonEmpty"},
        "primitive_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "source_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "failure_signature": {"$ref": "#/$defs/nonEmpty"},
        "fairness_basis": {"$ref": "#/$defs/nonEmpty"}
      }
    },
    "artifactContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "path", "media_type", "minimum_acceptable", "excellent", "machine_inspectable"],
      "properties": {
        "artifact_id": {"$ref": "#/$defs/identifier"},
        "path": {"$ref": "#/$defs/relativePath"},
        "media_type": {"$ref": "#/$defs/nonEmpty"},
        "minimum_acceptable": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}},
        "excellent": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}},
        "machine_inspectable": {"type": "boolean"}
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "description", "kind", "visibility", "primitive_ids", "public_basis_primitive_ids", "artifact_ids", "observable_evidence", "pass_criteria", "fail_criteria", "failure_signatures", "disclosure_basis"],
      "properties": {
        "check_id": {"$ref": "#/$defs/identifier"},
        "description": {"$ref": "#/$defs/nonEmpty"},
        "kind": {"enum": ["deterministic", "spreadsheet", "state", "llm_judge", "human_judge", "pairwise"]},
        "visibility": {"$ref": "#/$defs/visibility"},
        "primitive_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "public_basis_primitive_ids": {"$ref": "#/$defs/idList"},
        "artifact_ids": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/identifier"}, "uniqueItems": true},
        "observable_evidence": {"$ref": "#/$defs/nonEmpty"},
        "pass_criteria": {"$ref": "#/$defs/nonEmpty"},
        "fail_criteria": {"$ref": "#/$defs/nonEmpty"},
        "failure_signatures": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}},
        "disclosure_basis": {"enum": ["direct_public_requirement", "public_principle_consequence", "safety_necessity", "internal_calibration_only"]}
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "status", "owner", "criteria", "evidence_paths"],
      "properties": {
        "stage": {"$ref": "#/$defs/stage"},
        "status": {"enum": ["not_run", "passed", "blocked", "failed"]},
        "owner": {"$ref": "#/$defs/identifier"},
        "criteria": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/nonEmpty"}},
        "evidence_paths": {"type": "array", "items": {"$ref": "#/$defs/relativePath"}, "uniqueItems": true},
        "notes": {"type": "string"}
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "leakage_review", "expert_validity_review", "known_limitations"],
      "properties": {
        "status": {"enum": ["not_ready", "pilot_only", "releasable"]},
        "leakage_review": {"enum": ["not_run", "passed", "failed"]},
        "expert_validity_review": {"enum": ["not_run", "passed", "failed"]},
        "known_limitations": {"type": "array", "items": {"$ref": "#/$defs/nonEmpty"}}
      }
    }
  }
}
