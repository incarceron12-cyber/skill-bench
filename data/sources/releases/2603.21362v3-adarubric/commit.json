      "patch": "@@ -53,6 +53,12 @@ python_version = \"3.10\"\n strict = true\n plugins = [\"pydantic.mypy\"]\n \n+# pyyaml is an optional extra without type stubs. Suppress per-module so the\n+# result is identical whether or not pyyaml is installed in the environment.\n+[[tool.mypy.overrides]]\n+module = \"yaml\"\n+ignore_missing_imports = true\n+\n [tool.pytest.ini_options]\n asyncio_mode = \"auto\"\n testpaths = [\"tests\"]"
