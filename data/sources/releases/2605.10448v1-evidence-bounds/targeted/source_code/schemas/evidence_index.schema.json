{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence_index.schema.json",
  "title": "EvidenceIndex",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "domain",
    "benchmark_name",
    "case_unit_id",
    "paired",
    "arms",
    "released_evaluator_label_available",
    "released_evaluator_label_source",
    "released_evaluator_artifacts",
    "run_status_artifacts",
    "primary_artifacts",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "evidence_index_v1"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_name": {
      "type": "string",
      "minLength": 1
    },
    "case_unit_id": {
      "type": "string",
      "minLength": 1
    },
    "paired": {
      "type": "boolean"
    },
    "arms": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ArmEntry"
      }
    },
    "released_evaluator_label_available": {
      "type": "boolean"
    },
    "released_evaluator_label_source": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "released_evaluator_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "run_status_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "primary_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "ArmEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "artifacts"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
