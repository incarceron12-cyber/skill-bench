{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "case_checklist.schema.json",
  "title": "CaseChecklist",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_unit_id",
    "domain",
    "task_id",
    "native",
    "stronger"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "case_checklist_v1"
    },
    "case_unit_id": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "native": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_goal",
        "benchmark_success",
        "checked_by",
        "decisive_artifacts",
        "success_if",
        "fail_if",
        "undecided_if"
      ],
      "properties": {
        "user_goal": { "$ref": "#/$defs/JustifiedText" },
        "benchmark_success": { "$ref": "#/$defs/JustifiedText" },
        "checked_by": { "$ref": "#/$defs/JustifiedText" },
        "decisive_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ArtifactQuestion" }
        },
        "success_if": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/JustifiedText" }
        },
        "fail_if": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/JustifiedText" }
        },
        "undecided_if": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/JustifiedText" }
        }
      }
    },
    "stronger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["additional_conditions"],
      "properties": {
        "additional_conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/StrongerCondition" }
        }
      }
    }
  },
  "$defs": {
    "Pointer": {
      "type": "string",
      "minLength": 1,
      "description": "Use <relative_path>::<symbol|yaml_path|line_span>."
    },
    "JustifiedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "support": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Pointer" }
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        { "required": ["support"] },
        { "required": ["rationale"] }
      ]
    },
    "ArtifactQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "question", "support"],
      "properties": {
        "artifact": {
          "type": "string",
          "minLength": 1
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "support": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Pointer" }
        }
      }
    },
    "StrongerCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "rationale", "decisive_artifacts", "support"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "decisive_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ArtifactQuestion" }
        },
        "support": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Pointer" }
        }
      }
    }
  }
}
