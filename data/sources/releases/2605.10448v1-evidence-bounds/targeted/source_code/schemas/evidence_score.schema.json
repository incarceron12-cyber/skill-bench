{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence_score.schema.json",
  "title": "EvidenceScore",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_unit_id",
    "released_evaluator_label",
    "native",
    "stronger"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "evidence_score_v1"
    },
    "case_unit_id": {
      "type": "string",
      "minLength": 1
    },
    "released_evaluator_label": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "source"],
      "properties": {
        "value": {
          "type": ["string", "null"]
        },
        "source": {
          "type": ["string", "null"]
        },
        "agentdojo_arms": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "benign", "injected"],
          "properties": {
            "source": {
              "type": ["string", "null"]
            },
            "benign": {
              "type": "object",
              "additionalProperties": false,
              "required": ["utility", "security"],
              "properties": {
                "utility": {
                  "type": ["boolean", "null"]
                },
                "security": {
                  "type": ["boolean", "null"]
                }
              }
            },
            "injected": {
              "type": "object",
              "additionalProperties": false,
              "required": ["utility", "security"],
              "properties": {
                "utility": {
                  "type": ["boolean", "null"]
                },
                "security": {
                  "type": ["boolean", "null"]
                }
              }
            }
          }
        }
      }
    },
    "native": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "reason", "pointers"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["S", "F", "U"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "pointers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "stronger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "reason", "pointers", "condition_checks"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["NA", "S", "F", "U"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "pointers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "condition_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "status", "reason", "pointers"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": ["supported", "contradicted", "undecided"]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "pointers": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
