      "patch": "@@ -26,8 +26,15 @@ body:\n   - type: input\n     id: link\n     attributes:\n-      label: Link\n-      description: Enter the link to the paper or the GitHub repository of the judge model. This is what will be displayed on the leaderboard.\n+      label: Project URL\n+      description: Enter the URL to the arxiv paper or the GitHub repository of the judge model. This is what will be displayed on the leaderboard. Only include one link.\n+\n+  - type: input\n+    id: results\n+    attributes:\n+      label: Results URL\n+      description: Enter the URL to the results in JSON format. For an example, see [this example](https://huggingface.co/datasets/Zery/WSM-7B-AgentRewardBench/raw/main/results.json).\n+\n   \n   - type: input\n     id: precision\n@@ -41,7 +48,7 @@ body:\n   - type: input\n     id: recall\n     attributes:\n-      label: Overall\n+      label: Recall\n       description: Report your overall recall score (numerical between 0 and 1).\n       placeholder: \"0.0\"\n     validations:\n@@ -100,3 +107,4 @@ body:\n       placeholder: \"0.0\"\n     validations:\n       required: true\n+",
